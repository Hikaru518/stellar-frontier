{
  "name": "stellar-frontier-monorepo",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.1",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "node common/scripts/install-run-rush-pnpm.js run --filter @stellar-frontier/pc-client dev",
    "dev:pc": "node common/scripts/install-run-rush-pnpm.js run --filter @stellar-frontier/pc-client dev",
    "dev:mobile": "node common/scripts/install-run-rush-pnpm.js run --filter @stellar-frontier/mobile-client dev",
    "dev:mobile:lan": "node common/scripts/install-run-rush-pnpm.js run --filter @stellar-frontier/mobile-client dev:lan",
    "editor:dev": "node common/scripts/install-run-rush-pnpm.js run --filter @stellar-frontier/editor dev",
    "editor:helper": "node common/scripts/install-run-rush-pnpm.js run --filter @stellar-frontier/editor helper",
    "editor:build": "node common/scripts/install-run-rush-pnpm.js run --filter @stellar-frontier/editor build",
    "editor:test": "node common/scripts/install-run-rush-pnpm.js run --filter @stellar-frontier/editor test",
    "preview": "node common/scripts/install-run-rush-pnpm.js run --filter @stellar-frontier/pc-client preview",
    "rush:update": "node common/scripts/install-run-rush.js update",
    "build": "node common/scripts/install-run-rush.js build",
    "lint": "node common/scripts/install-run-rush.js lint",
    "test": "node common/scripts/install-run-rush.js test",
    "test:e2e": "node common/scripts/install-run-rush.js test:e2e --to @stellar-frontier/pc-client",
    "validate:content": "node common/scripts/install-run-rush.js validate-content",
    "rush:list": "node common/scripts/install-run-rush.js list"
  }
}
