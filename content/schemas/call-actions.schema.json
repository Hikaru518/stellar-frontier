{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stellar-frontier.local/schemas/call-actions.schema.json",
  "title": "Stellar Frontier Call Actions",
  "type": "object",
  "additionalProperties": false,
  "required": ["call_actions"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "call_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/callAction"
      }
    }
  },
  "$defs": {
    "actionId": {
      "type": "string",
      "enum": ["move", "survey", "gather", "build", "standby", "extract", "scan", "stop"]
    },
    "category": {
      "type": "string",
      "enum": ["universal", "object_action"]
    },
    "localizedText": {
      "type": "string",
      "minLength": 1
    },
    "tone": {
      "type": "string",
      "enum": ["neutral", "accent", "muted", "danger", "success"]
    },
    "mapObjectKind": {
      "type": "string",
      "enum": ["resourceNode", "structure", "signal", "hazard", "facility", "ruin", "landmark"]
    },
    "handlerId": {
      "type": "string",
      "pattern": "^[a-z][a-zA-Z0-9_]*$"
    },
    "callAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "category", "label", "tone", "availableWhenBusy", "durationSeconds", "handler"],
      "properties": {
        "id": {
          "$ref": "#/$defs/actionId"
        },
        "category": {
          "$ref": "#/$defs/category"
        },
        "label": {
          "$ref": "#/$defs/localizedText"
        },
        "tone": {
          "$ref": "#/$defs/tone"
        },
        "availableWhenBusy": {
          "type": "boolean",
          "default": false
        },
        "applicableObjectKinds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/mapObjectKind"
          },
          "uniqueItems": true
        },
        "durationSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "handler": {
          "$ref": "#/$defs/handlerId"
        },
        "params": {
          "type": "object",
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "category": {
                "const": "object_action"
              }
            },
            "required": ["category"]
          },
          "then": {
            "required": ["applicableObjectKinds"]
          }
        }
      ]
    }
  }
}
