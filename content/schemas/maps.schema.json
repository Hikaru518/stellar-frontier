{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stellar-frontier.local/schemas/maps.schema.json",
  "title": "Stellar Frontier Maps",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "version", "size", "originTileId", "initialDiscoveredTileIds", "radar", "tiles"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "$ref": "#/$defs/id"
    },
    "name": {
      "$ref": "#/$defs/localizedText"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "size": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rows", "cols"],
      "properties": {
        "rows": {
          "type": "integer",
          "minimum": 1
        },
        "cols": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "originTileId": {
      "$ref": "#/$defs/tileId"
    },
    "initialDiscoveredTileIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/tileId"
      },
      "uniqueItems": true
    },
    "radar": {
      "$ref": "#/$defs/radar"
    },
    "tiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/tile"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "tileId": {
      "type": "string",
      "pattern": "^[0-9]+-[0-9]+$"
    },
    "localizedText": {
      "type": "string",
      "minLength": 1
    },
    "tag": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "visibility": {
      "type": "string",
      "enum": ["onDiscovered", "onInvestigated", "hidden"]
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["temperatureCelsius", "humidityPercent", "magneticFieldMicroTesla", "radiationLevel"],
      "properties": {
        "temperatureCelsius": {
          "type": "number"
        },
        "humidityPercent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "magneticFieldMicroTesla": {
          "type": "number"
        },
        "radiationLevel": {
          "type": "string",
          "enum": ["none", "low", "medium", "high", "critical"]
        },
        "toxicityLevel": {
          "type": "string",
          "enum": ["none", "low", "medium", "high", "critical"]
        },
        "atmosphericPressureKpa": {
          "type": "number"
        },
        "notes": {
          "$ref": "#/$defs/localizedText"
        }
      }
    },
    "mapObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "name", "visibility"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "kind": {
          "type": "string",
          "enum": ["resourceNode", "structure", "signal", "hazard", "facility", "ruin", "landmark"]
        },
        "name": {
          "$ref": "#/$defs/localizedText"
        },
        "description": {
          "$ref": "#/$defs/localizedText"
        },
        "visibility": {
          "type": "string",
          "enum": ["onDiscovered", "onInvestigated"]
        },
        "tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tag"
          }
        },
        "candidateActions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["move", "survey", "gather", "build", "standby", "extract", "scan"]
          }
        }
      }
    },
    "specialState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "visibility", "severity", "startsActive"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/localizedText"
        },
        "description": {
          "$ref": "#/$defs/localizedText"
        },
        "visibility": {
          "$ref": "#/$defs/visibility"
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tag"
          }
        },
        "dangerTags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tag"
          }
        },
        "startsActive": {
          "type": "boolean"
        },
        "durationGameSeconds": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "radar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["world", "glyphRows", "toneRows", "palette", "symbols", "trace", "regions"],
      "properties": {
        "world": {
          "$ref": "#/$defs/radarWorld"
        },
        "glyphRows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "toneRows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "pattern": "^[a-z]+$"
          }
        },
        "palette": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "type": "string",
            "pattern": "^[a-z]$"
          },
          "additionalProperties": {
            "type": "string",
            "pattern": "^#[0-9a-fA-F]{6}$"
          }
        },
        "symbols": {
          "$ref": "#/$defs/radarSymbols"
        },
        "trace": {
          "$ref": "#/$defs/radarTrace"
        },
        "regions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/radarRegion"
          }
        }
      }
    },
    "radarWorld": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height", "origin"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "origin": {
          "type": "object",
          "additionalProperties": false,
          "required": ["x", "y"],
          "properties": {
            "x": { "type": "integer", "minimum": 0 },
            "y": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "radarSymbols": {
      "type": "object",
      "additionalProperties": false,
      "required": ["crew", "focus"],
      "properties": {
        "crew": { "$ref": "#/$defs/radarSymbol" },
        "focus": { "$ref": "#/$defs/radarSymbol" }
      }
    },
    "radarSymbol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["glyph", "tone"],
      "properties": {
        "glyph": { "type": "string", "minLength": 1, "maxLength": 1 },
        "tone": { "type": "string", "pattern": "^[a-z]$" }
      }
    },
    "radarTrace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layerNotice", "controlMode", "callMode", "worldLine", "jsonLine", "emptyLine"],
      "properties": {
        "layerNotice": { "$ref": "#/$defs/localizedText" },
        "controlMode": { "$ref": "#/$defs/localizedText" },
        "callMode": { "$ref": "#/$defs/localizedText" },
        "worldLine": { "$ref": "#/$defs/localizedText" },
        "jsonLine": { "$ref": "#/$defs/localizedText" },
        "emptyLine": { "$ref": "#/$defs/localizedText" }
      }
    },
    "radarRegion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "priority", "shape", "tone"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "label": { "$ref": "#/$defs/localizedText" },
        "priority": { "type": "integer" },
        "shape": {
          "oneOf": [
            { "$ref": "#/$defs/radarCircleShape" },
            { "$ref": "#/$defs/radarBoxShape" }
          ]
        },
        "tone": { "type": "string", "pattern": "^[a-z]$" }
      }
    },
    "radarCircleShape": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "x", "y", "radius"],
      "properties": {
        "type": { "const": "circle" },
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "radius": { "type": "number", "minimum": 0 }
      }
    },
    "radarBoxShape": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "x1", "y1", "x2", "y2"],
      "properties": {
        "type": { "const": "box" },
        "x1": { "type": "integer", "minimum": 0 },
        "y1": { "type": "integer", "minimum": 0 },
        "x2": { "type": "integer", "minimum": 0 },
        "y2": { "type": "integer", "minimum": 0 }
      }
    },
    "tile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "row", "col", "areaName", "terrain", "weather", "environment", "objectIds", "specialStates"],
      "properties": {
        "id": {
          "$ref": "#/$defs/tileId"
        },
        "row": {
          "type": "integer",
          "minimum": 1
        },
        "col": {
          "type": "integer",
          "minimum": 1
        },
        "areaName": {
          "$ref": "#/$defs/localizedText"
        },
        "terrain": {
          "type": "string",
          "enum": ["平原", "水", "森林 / 山", "山", "丘陵", "旧医疗前哨", "坠落广播塔", "沙漠", "裂谷", "高地", "荒原"]
        },
        "weather": {
          "type": "string",
          "enum": ["晴朗", "阴天", "薄雾", "强风", "沙尘", "酸雨", "静电风暴"]
        },
        "environment": {
          "$ref": "#/$defs/environment"
        },
        "objectIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "specialStates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/specialState"
          }
        }
      }
    }
  }
}
