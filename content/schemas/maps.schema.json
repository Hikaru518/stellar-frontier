{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stellar-frontier.local/schemas/maps.schema.json",
  "title": "Stellar Frontier Maps",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "version", "size", "originTileId", "initialDiscoveredTileIds", "radarPath", "tiles"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "id": {
      "$ref": "#/$defs/id"
    },
    "name": {
      "$ref": "#/$defs/localizedText"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "size": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rows", "cols"],
      "properties": {
        "rows": {
          "type": "integer",
          "minimum": 1
        },
        "cols": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "originTileId": {
      "$ref": "#/$defs/tileId"
    },
    "initialDiscoveredTileIds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/tileId"
      },
      "uniqueItems": true
    },
    "radarPath": {
      "type": "string",
      "pattern": "^content/maps/radar/[a-z][a-z0-9_-]*\\.json$"
    },
    "tiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/tile"
      }
    },
    "features": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mapFeature"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "tileId": {
      "type": "string",
      "pattern": "^[0-9]+-[0-9]+$"
    },
    "localizedText": {
      "type": "string",
      "minLength": 1
    },
    "tag": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "colonId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*(?::[a-z][a-z0-9_-]*)*$"
    },
    "customKind": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_-]*(?::[A-Za-z][A-Za-z0-9_-]*)*$"
    },
    "tone": {
      "type": "string",
      "enum": ["neutral", "muted", "accent", "danger", "success"]
    },
    "visibility": {
      "type": "string",
      "enum": ["onDiscovered", "onInvestigated", "hidden"]
    },
    "mapFeatureVisibility": {
      "type": "string",
      "enum": ["always", "onDiscovered", "onInvestigated", "hidden"]
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["temperatureCelsius", "humidityPercent", "magneticFieldMicroTesla", "radiationLevel"],
      "properties": {
        "temperatureCelsius": {
          "type": "number"
        },
        "humidityPercent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "magneticFieldMicroTesla": {
          "type": "number"
        },
        "radiationLevel": {
          "type": "string",
          "enum": ["none", "low", "medium", "high", "critical"]
        },
        "toxicityLevel": {
          "type": "string",
          "enum": ["none", "low", "medium", "high", "critical"]
        },
        "atmosphericPressureKpa": {
          "type": "number"
        },
        "notes": {
          "$ref": "#/$defs/localizedText"
        }
      }
    },
    "specialState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "visibility", "severity", "startsActive"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/localizedText"
        },
        "description": {
          "$ref": "#/$defs/localizedText"
        },
        "visibility": {
          "$ref": "#/$defs/visibility"
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tag"
          }
        },
        "dangerTags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tag"
          }
        },
        "startsActive": {
          "type": "boolean"
        },
        "durationGameSeconds": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "featureFootprint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "spans"],
      "properties": {
        "type": {
          "type": "string",
          "const": "row_spans"
        },
        "spans": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/featureRowSpan"
          }
        }
      }
    },
    "featureRowSpan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["row", "colStart", "colEnd"],
      "properties": {
        "row": {
          "type": "integer",
          "minimum": 1
        },
        "colStart": {
          "type": "integer",
          "minimum": 1
        },
        "colEnd": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "featureActionEffect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "feature_id", "status"],
      "properties": {
        "type": {
          "type": "string",
          "const": "set_feature_status"
        },
        "feature_id": {
          "$ref": "#/$defs/id"
        },
        "status": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "featureLocalAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "duration_seconds", "success_effects", "failure_effects"],
      "properties": {
        "kind": {
          "type": "string",
          "const": "timed_repair"
        },
        "duration_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "success_effects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/featureActionEffect"
          }
        },
        "failure_effects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/featureActionEffect"
          }
        }
      }
    },
    "featureActionDef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "category", "label", "conditions"],
      "properties": {
        "id": {
          "$ref": "#/$defs/colonId"
        },
        "category": {
          "type": "string",
          "const": "feature"
        },
        "label": {
          "$ref": "#/$defs/localizedText"
        },
        "tone": {
          "$ref": "#/$defs/tone"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "event_id": {
          "type": "string",
          "minLength": 1
        },
        "display_when_unavailable": {
          "type": "string",
          "enum": ["disabled"]
        },
        "unavailable_hint": {
          "$ref": "#/$defs/localizedText"
        },
        "local_action": {
          "$ref": "#/$defs/featureLocalAction"
        }
      }
    },
    "mapFeature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "kind", "priority", "visibility", "footprint"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/localizedText"
        },
        "description": {
          "$ref": "#/$defs/localizedText"
        },
        "kind": {
          "$ref": "#/$defs/customKind"
        },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tag"
          }
        },
        "visibility": {
          "$ref": "#/$defs/mapFeatureVisibility"
        },
        "footprint": {
          "$ref": "#/$defs/featureFootprint"
        },
        "investigatable": {
          "type": "boolean"
        },
        "status_options": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "initial_status": {
          "type": "string",
          "minLength": 1
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/featureActionDef"
          }
        }
      },
      "allOf": [
        {
          "if": {
            "required": ["investigatable"],
            "properties": {
              "investigatable": {
                "const": true
              }
            }
          },
          "then": {
            "required": ["status_options", "initial_status", "actions"]
          },
          "else": {
            "not": {
              "anyOf": [
                { "required": ["status_options"] },
                { "required": ["initial_status"] },
                { "required": ["actions"] }
              ]
            }
          }
        }
      ]
    },
    "tile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "row", "col", "terrain", "weather", "environment", "specialStates"],
      "properties": {
        "id": {
          "$ref": "#/$defs/tileId"
        },
        "row": {
          "type": "integer",
          "minimum": 1
        },
        "col": {
          "type": "integer",
          "minimum": 1
        },
        "terrain": {
          "type": "string",
          "enum": ["平原", "水", "森林 / 山", "山", "丘陵", "旧医疗前哨", "坠落广播塔", "沙漠", "裂谷", "高地", "荒原"]
        },
        "weather": {
          "type": "string",
          "enum": ["晴朗", "阴天", "薄雾", "强风", "沙尘", "酸雨", "静电风暴"]
        },
        "environment": {
          "$ref": "#/$defs/environment"
        },
        "specialStates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/specialState"
          }
        }
      }
    }
  }
}
