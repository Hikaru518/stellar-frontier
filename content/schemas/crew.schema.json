{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stellar-frontier.local/schemas/crew.schema.json",
  "title": "Stellar Frontier Crew",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "crew"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "crew": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/crewMember"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "localizedText": {
      "type": "string",
      "minLength": 1
    },
    "attributeMap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["physical", "agility", "intellect", "perception", "luck"],
      "properties": {
        "physical": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6
        },
        "agility": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6
        },
        "intellect": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6
        },
        "perception": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6
        },
        "luck": {
          "type": "integer",
          "minimum": 1,
          "maximum": 6
        }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["originWorld", "originProfession", "experience", "selfIntro"],
      "properties": {
        "originWorld": {
          "$ref": "#/$defs/localizedText"
        },
        "originProfession": {
          "$ref": "#/$defs/localizedText"
        },
        "experience": {
          "$ref": "#/$defs/localizedText"
        },
        "selfIntro": {
          "$ref": "#/$defs/localizedText"
        }
      }
    },
    "expertiseRuleEffect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "resourceId", "amount", "chance", "customLogText"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["surveyBonus"]
        },
        "resourceId": {
          "$ref": "#/$defs/id"
        },
        "amount": {
          "type": "integer",
          "minimum": 1
        },
        "chance": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "customLogText": {
          "$ref": "#/$defs/localizedText"
        },
        "tileId": {
          "type": "string",
          "pattern": "^[0-9]+-[0-9]+$"
        }
      }
    },
    "expertiseEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expertiseId", "name", "description"],
      "properties": {
        "expertiseId": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "$ref": "#/$defs/localizedText"
        },
        "description": {
          "$ref": "#/$defs/localizedText"
        },
        "ruleEffect": {
          "$ref": "#/$defs/expertiseRuleEffect"
        }
      }
    },
    "diaryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entryId", "triggerNode", "gameSecond", "text", "availability"],
      "properties": {
        "entryId": {
          "$ref": "#/$defs/id"
        },
        "triggerNode": {
          "$ref": "#/$defs/localizedText"
        },
        "gameSecond": {
          "type": "integer",
          "minimum": 0
        },
        "text": {
          "$ref": "#/$defs/localizedText"
        },
        "availability": {
          "type": "string",
          "enum": ["delivered", "pending", "lostBlocked", "recovered"]
        }
      }
    },
    "inventoryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["itemId", "quantity"],
      "properties": {
        "itemId": {
          "$ref": "#/$defs/id"
        },
        "quantity": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "activeAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actionType", "status", "targetTile", "durationSeconds"],
      "properties": {
        "actionType": {
          "type": "string",
          "enum": ["move", "gather", "build", "survey", "standby", "event"]
        },
        "status": {
          "type": "string",
          "enum": ["pending", "inProgress", "completed", "interrupted", "failed"]
        },
        "targetTile": {
          "type": "string",
          "pattern": "^[0-9]+-[0-9]+$"
        },
        "durationSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "resourceId": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "emergencyEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventId", "dangerStage", "deadlineSeconds"],
      "properties": {
        "eventId": {
          "$ref": "#/$defs/id"
        },
        "dangerStage": {
          "type": "integer",
          "minimum": 0
        },
        "deadlineSeconds": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "crewMember": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "crewId",
        "name",
        "role",
        "currentTile",
        "status",
        "statusTone",
        "attributes",
        "inventory",
        "canCommunicate",
        "lastContactTime",
        "profile",
        "voiceTone",
        "personalityTags",
        "expertise",
        "diaryEntries"
      ],
      "properties": {
        "crewId": {
          "type": "string",
          "enum": ["mike", "amy", "garry"]
        },
        "name": {
          "$ref": "#/$defs/localizedText"
        },
        "role": {
          "$ref": "#/$defs/localizedText"
        },
        "currentTile": {
          "type": "string",
          "pattern": "^[0-9]+-[0-9]+$"
        },
        "status": {
          "type": "string",
          "enum": ["idle", "moving", "working", "inEvent", "lost", "dead"]
        },
        "statusTone": {
          "type": "string",
          "enum": ["neutral", "muted", "accent", "danger", "success"]
        },
        "attributes": {
          "$ref": "#/$defs/attributeMap"
        },
        "skills": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "inventory": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/inventoryEntry"
          }
        },
        "profile": {
          "$ref": "#/$defs/profile"
        },
        "voiceTone": {
          "$ref": "#/$defs/localizedText"
        },
        "personalityTags": {
          "type": "array",
          "minItems": 3,
          "maxItems": 5,
          "items": {
            "$ref": "#/$defs/localizedText"
          }
        },
        "expertise": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/expertiseEntry"
          }
        },
        "diaryEntries": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/diaryEntry"
          }
        },
        "canCommunicate": {
          "type": "boolean"
        },
        "lastContactTime": {
          "type": "integer",
          "minimum": 0
        },
        "activeAction": {
          "$ref": "#/$defs/activeAction"
        },
        "emergencyEvent": {
          "$ref": "#/$defs/emergencyEvent"
        },
        "unavailable": {
          "type": "boolean"
        }
      }
    }
  }
}
