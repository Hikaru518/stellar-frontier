{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stellar-frontier.local/schemas/map-radar.schema.json",
  "title": "Stellar Frontier Map Radar",
  "type": "object",
  "additionalProperties": false,
  "required": ["mapId", "world", "palette", "symbols", "trace", "regions"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "mapId": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$"
    },
    "world": {
      "$ref": "#/$defs/radarWorld"
    },
    "glyphRows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "toneRows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z]+$"
      }
    },
    "palette": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "type": "string",
        "pattern": "^[a-z]$"
      },
      "additionalProperties": {
        "type": "string",
        "pattern": "^#[0-9a-fA-F]{6}$"
      }
    },
    "baseLayer": {
      "$ref": "#/$defs/radarAssetReference"
    },
    "symbols": {
      "$ref": "#/$defs/radarSymbols"
    },
    "trace": {
      "$ref": "#/$defs/radarTrace"
    },
    "regions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/radarRegion"
      }
    },
    "renderLayers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/radarRenderLayer"
      }
    }
  },
  "$defs": {
    "localizedText": {
      "type": "string",
      "minLength": 1
    },
    "radarWorld": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height", "origin"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "origin": {
          "type": "object",
          "additionalProperties": false,
          "required": ["x", "y"],
          "properties": {
            "x": { "type": "integer", "minimum": 0 },
            "y": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "radarSymbols": {
      "type": "object",
      "additionalProperties": false,
      "required": ["crew", "focus"],
      "properties": {
        "crew": { "$ref": "#/$defs/radarSymbolOrAsset" },
        "focus": { "$ref": "#/$defs/radarSymbolOrAsset" }
      }
    },
    "radarSymbolOrAsset": {
      "oneOf": [
        { "$ref": "#/$defs/radarSymbol" },
        { "$ref": "#/$defs/radarAssetReference" }
      ]
    },
    "radarSymbol": {
      "type": "object",
      "additionalProperties": false,
      "required": ["glyph", "tone"],
      "properties": {
        "glyph": { "type": "string", "minLength": 1, "maxLength": 1 },
        "tone": { "type": "string", "pattern": "^[a-z]$" }
      }
    },
    "radarAssetReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assetId"],
      "properties": {
        "assetId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        }
      }
    },
    "radarTrace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["layerNotice", "controlMode", "callMode", "worldLine", "jsonLine", "emptyLine"],
      "properties": {
        "layerNotice": { "$ref": "#/$defs/localizedText" },
        "controlMode": { "$ref": "#/$defs/localizedText" },
        "callMode": { "$ref": "#/$defs/localizedText" },
        "worldLine": { "$ref": "#/$defs/localizedText" },
        "jsonLine": { "$ref": "#/$defs/localizedText" },
        "emptyLine": { "$ref": "#/$defs/localizedText" }
      }
    },
    "radarRegion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "priority", "shape", "tone"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "label": { "$ref": "#/$defs/localizedText" },
        "priority": { "type": "integer" },
        "shape": {
          "oneOf": [
            { "$ref": "#/$defs/radarCircleShape" },
            { "$ref": "#/$defs/radarBoxShape" }
          ]
        },
        "tone": { "type": "string", "pattern": "^[a-z]$" }
      }
    },
    "radarCircleShape": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "x", "y", "radius"],
      "properties": {
        "type": { "const": "circle" },
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "radius": { "type": "number", "minimum": 0 }
      }
    },
    "radarBoxShape": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "x1", "y1", "x2", "y2"],
      "properties": {
        "type": { "const": "box" },
        "x1": { "type": "integer", "minimum": 0 },
        "y1": { "type": "integer", "minimum": 0 },
        "x2": { "type": "integer", "minimum": 0 },
        "y2": { "type": "integer", "minimum": 0 }
      }
    },
    "radarRenderLayer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "visible", "items"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "name": { "$ref": "#/$defs/localizedText" },
        "visible": { "type": "boolean" },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/radarRenderItem"
          }
        }
      }
    },
    "radarRenderItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "x", "y"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_-]*$"
        },
        "x": { "type": "integer", "minimum": 0 },
        "y": { "type": "integer", "minimum": 0 },
        "assetId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "tone": { "type": "string", "pattern": "^[a-z]$" },
        "glyphRows": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "toneRows": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[a-z]+$"
          }
        }
      },
      "oneOf": [
        { "required": ["assetId"] },
        { "required": ["glyphRows"] }
      ]
    }
  }
}
