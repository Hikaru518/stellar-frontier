{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stellar-frontier.local/schemas/map-objects.schema.json",
  "title": "Stellar Frontier Map Objects",
  "type": "object",
  "additionalProperties": false,
  "required": ["map_objects"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "map_objects": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mapObject"
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*(?::[a-z][a-z0-9_-]*)*$"
    },
    "tag": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "localizedText": {
      "type": "string",
      "minLength": 1
    },
    "tone": {
      "type": "string",
      "enum": ["neutral", "muted", "accent", "danger", "success"]
    },
    "visibility": {
      "type": "string",
      "enum": ["onDiscovered", "onInvestigated", "hidden"]
    },
    "kind": {
      "type": "string",
      "enum": ["resourceNode", "structure", "signal", "hazard", "facility", "ruin", "landmark"]
    },
    "actionDef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "category", "label", "conditions"],
      "anyOf": [{ "required": ["event_id"] }, { "required": ["local_action"] }],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "category": {
          "type": "string",
          "enum": ["universal", "object"]
        },
        "label": {
          "$ref": "#/$defs/localizedText"
        },
        "tone": {
          "$ref": "#/$defs/tone"
        },
        "conditions": {
          "type": "array",
          "items": {
            "type": "object"
          }
        },
        "event_id": {
          "type": "string",
          "minLength": 1
        },
        "display_when_unavailable": {
          "type": "string",
          "enum": ["disabled"]
        },
        "unavailable_hint": {
          "$ref": "#/$defs/localizedText"
        },
        "action_ref": {
          "type": "string",
          "minLength": 1
        },
        "local_action": {
          "$ref": "#/$defs/localAction"
        }
      }
    },
    "localActionEffect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "object_id", "status"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["set_object_status"]
        },
        "object_id": {
          "$ref": "#/$defs/id"
        },
        "status": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "localRepairSuccessCheck": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attribute", "base", "ratio", "bias", "difficulty", "min", "max"],
      "properties": {
        "attribute": {
          "type": "string",
          "enum": ["agility"]
        },
        "base": {
          "type": "number"
        },
        "ratio": {
          "type": "number"
        },
        "bias": {
          "type": "number"
        },
        "difficulty": {
          "type": "number"
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        }
      }
    },
    "localAction": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "duration_seconds", "success_check", "success_effects", "failure_effects"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["timed_repair"]
        },
        "duration_seconds": {
          "type": "integer",
          "minimum": 1
        },
        "success_check": {
          "$ref": "#/$defs/localRepairSuccessCheck"
        },
        "success_effects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/localActionEffect"
          }
        },
        "failure_effects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/localActionEffect"
          }
        }
      }
    },
    "mapObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "name", "visibility", "status_options", "initial_status", "actions"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "kind": {
          "$ref": "#/$defs/kind"
        },
        "name": {
          "$ref": "#/$defs/localizedText"
        },
        "description": {
          "$ref": "#/$defs/localizedText"
        },
        "tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/tag"
          }
        },
        "status_options": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "initial_status": {
          "type": "string",
          "minLength": 1
        },
        "actions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/actionDef"
          }
        },
        "visibility": {
          "$ref": "#/$defs/visibility"
        }
      }
    }
  }
}
