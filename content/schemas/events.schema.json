{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stellar-frontier.local/schemas/events.schema.json",
  "title": "Stellar Frontier Events",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "events"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "events": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/event"
      },
      "uniqueItems": true
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "localizedText": {
      "type": "string",
      "minLength": 1
    },
    "condition": {
      "type": "string",
      "minLength": 1
    },
    "modifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["condition", "chance"],
      "properties": {
        "condition": {
          "$ref": "#/$defs/condition"
        },
        "chance": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        }
      }
    },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source"],
      "properties": {
        "source": {
          "type": "string",
          "enum": ["arrival", "surveyComplete", "gatherComplete", "buildComplete", "idleTime", "callChoice"]
        },
        "tileTypes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "actionTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["move", "gather", "build", "survey", "standby", "event"]
          }
        },
        "surveyLevel": {
          "type": "string",
          "enum": ["quick", "standard", "deep"]
        },
        "minIdleSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "choiceId": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "effect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["addResource", "removeResource", "discoverResource", "updateTile", "updateCrewStatus", "addCrewCondition", "startEmergency", "addLog"]
        },
        "resource": {
          "$ref": "#/$defs/id"
        },
        "amount": {
          "type": "integer",
          "minimum": 0
        },
        "quality": {
          "$ref": "#/$defs/id"
        },
        "field": {
          "$ref": "#/$defs/id"
        },
        "value": {},
        "status": {
          "type": "string",
          "enum": ["idle", "moving", "working", "inEvent", "lost", "dead"]
        },
        "condition": {
          "$ref": "#/$defs/id"
        },
        "text": {
          "$ref": "#/$defs/localizedText"
        },
        "tone": {
          "type": "string",
          "enum": ["neutral", "muted", "accent", "danger", "success"]
        }
      }
    },
    "choice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["choiceId", "text"],
      "properties": {
        "choiceId": {
          "$ref": "#/$defs/id"
        },
        "text": {
          "$ref": "#/$defs/localizedText"
        },
        "hint": {
          "$ref": "#/$defs/localizedText"
        },
        "tone": {
          "type": "string",
          "enum": ["neutral", "muted", "accent", "danger", "success"]
        },
        "baseSuccessChance": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "dangerStageModifier": {
          "type": "number",
          "minimum": -1,
          "maximum": 1
        },
        "durationSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "successEffects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/effect"
          }
        },
        "failureEffects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/effect"
          }
        },
        "effects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/effect"
          }
        }
      }
    },
    "emergency": {
      "type": "object",
      "additionalProperties": false,
      "required": ["firstWaitSeconds", "escalationIntervalSeconds", "deadlineSeconds", "autoResolveResult"],
      "properties": {
        "firstWaitSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "escalationIntervalSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "deadlineSeconds": {
          "type": "integer",
          "minimum": 1
        },
        "autoResolveResult": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "event": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eventId", "title", "type", "priority", "scope", "repeatable", "cooldownSeconds", "trigger", "conditions", "baseChance", "modifiers", "durationSeconds", "effects", "choices", "resultText", "tags"],
      "properties": {
        "eventId": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "$ref": "#/$defs/localizedText"
        },
        "type": {
          "type": "string",
          "enum": ["arrival", "survey", "idle", "gather", "build", "emergency", "story", "reminder"]
        },
        "priority": {
          "type": "integer",
          "minimum": 0
        },
        "scope": {
          "type": "string",
          "enum": ["crew", "tile", "global"]
        },
        "repeatable": {
          "type": "boolean"
        },
        "cooldownSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "trigger": {
          "$ref": "#/$defs/trigger"
        },
        "conditions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/condition"
          }
        },
        "baseChance": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "modifiers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/modifier"
          }
        },
        "durationSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "effects": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/effect"
          }
        },
        "choices": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/choice"
          }
        },
        "emergency": {
          "anyOf": [
            {
              "$ref": "#/$defs/emergency"
            },
            {
              "type": "null"
            }
          ]
        },
        "resultText": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/localizedText"
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        }
      }
    }
  }
}
