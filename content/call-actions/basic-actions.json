{
  "$schema": "../schemas/call-actions.schema.json",
  "call_actions": [
    {
      "id": "survey",
      "category": "universal",
      "label": "调查当前区域",
      "tone": "neutral",
      "availableWhenBusy": false,
      "durationSeconds": 120,
      "handler": "survey",
      "params": {
        "surveyLevel": "standard"
      }
    },
    {
      "id": "move",
      "category": "universal",
      "label": "移动到指定区域",
      "tone": "neutral",
      "availableWhenBusy": false,
      "durationSeconds": 0,
      "handler": "move"
    },
    {
      "id": "standby",
      "category": "universal",
      "label": "原地待命",
      "tone": "muted",
      "availableWhenBusy": true,
      "durationSeconds": 0,
      "handler": "standby"
    },
    {
      "id": "stop",
      "category": "universal",
      "label": "停止当前行动",
      "tone": "danger",
      "availableWhenBusy": true,
      "durationSeconds": 10,
      "handler": "stop"
    }
  ]
}
