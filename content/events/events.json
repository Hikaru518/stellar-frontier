{
  "$schema": "../schemas/events.schema.json",
  "version": 1,
  "events": [
    {
      "eventId": "survey_forest_scattered_wood",
      "title": "散落的可用木材",
      "type": "survey",
      "priority": 10,
      "scope": "tile",
      "repeatable": true,
      "cooldownSeconds": 300,
      "trigger": {
        "source": "surveyComplete",
        "tileTypes": ["forest"],
        "surveyLevel": "standard"
      },
      "conditions": ["tile.resourceRemaining.wood != 0"],
      "baseChance": 0.3,
      "modifiers": [
        { "condition": "crew.attributes.perception >= 3", "chance": 0.1 },
        { "condition": "inventory.has(basic_tool)", "chance": 0.05 },
        { "condition": "tile.surveyCount >= 3", "chance": -0.15 }
      ],
      "durationSeconds": 0,
      "effects": [
        { "type": "addItem", "itemId": "wood", "target": "crewInventory", "amount": 2 },
        { "type": "addLog", "text": "队员从倒伏树枝中挑出了可用木材。", "tone": "success" }
      ],
      "choices": [],
      "emergency": null,
      "resultText": {
        "found": "在林地边缘找到一些干燥木材，已经整理带回。"
      },
      "tags": ["forest", "resource", "minor"]
    },
    {
      "eventId": "survey_hill_loose_ore",
      "title": "裸露的矿石碎片",
      "type": "survey",
      "priority": 10,
      "scope": "tile",
      "repeatable": true,
      "cooldownSeconds": 600,
      "trigger": {
        "source": "surveyComplete",
        "tileTypes": ["hill", "mountain"],
        "surveyLevel": "standard"
      },
      "conditions": [],
      "baseChance": 0.25,
      "modifiers": [
        { "condition": "crew.skills.has(mining)", "chance": 0.15 },
        { "condition": "inventory.has(scanner)", "chance": 0.1 }
      ],
      "durationSeconds": 0,
      "effects": [
        { "type": "addItem", "itemId": "iron_ore", "target": "crewInventory", "amount": 1 },
        { "type": "addLog", "text": "岩缝中有几块可以直接收集的矿石。", "tone": "success" }
      ],
      "choices": [],
      "emergency": null,
      "resultText": {
        "found": "发现几块裸露矿石，数量不多，但足够带回做样本。"
      },
      "tags": ["hill", "mountain", "resource", "minor"]
    },
    {
      "eventId": "survey_plain_old_campsite",
      "title": "旧营地痕迹",
      "type": "survey",
      "priority": 15,
      "scope": "tile",
      "repeatable": false,
      "cooldownSeconds": 0,
      "trigger": {
        "source": "surveyComplete",
        "tileTypes": ["plain", "forest"],
        "surveyLevel": "standard"
      },
      "conditions": ["notTriggered(survey_plain_old_campsite)"],
      "baseChance": 0.18,
      "modifiers": [
        { "condition": "crew.attributes.perception >= 3", "chance": 0.1 }
      ],
      "durationSeconds": 0,
      "effects": [
        { "type": "addLog", "text": "发现一处废弃营地，灰烬已经完全冷却。", "tone": "neutral" },
        { "type": "updateTile", "field": "lore_note", "value": "这里曾有人短暂停留。" }
      ],
      "choices": [],
      "emergency": null,
      "resultText": {
        "found": "队员发现了旧营地的痕迹，没有危险，但说明这里并非第一次有人经过。"
      },
      "tags": ["lore", "minor", "survey"]
    },
    {
      "eventId": "emergency_forest_beast",
      "title": "森林野兽遭遇",
      "type": "emergency",
      "priority": 80,
      "scope": "crew",
      "repeatable": true,
      "cooldownSeconds": 1200,
      "trigger": {
        "source": "surveyComplete",
        "tileTypes": ["forest"],
        "surveyLevel": "standard"
      },
      "conditions": ["crew.status != lost", "crew.status != dead"],
      "baseChance": 0.12,
      "modifiers": [
        { "condition": "tile.dangerLevel >= 2", "chance": 0.15 },
        { "condition": "crew.skills.has(survival)", "chance": -0.08 }
      ],
      "durationSeconds": 0,
      "effects": [
        { "type": "startEmergency" },
        { "type": "updateCrewStatus", "status": "inEvent" }
      ],
      "choices": [
        {
          "choiceId": "run",
          "text": "立刻撤离",
          "tone": "accent",
          "baseSuccessChance": 0.8,
          "dangerStageModifier": -0.1,
          "successEffects": [
            { "type": "updateCrewStatus", "status": "idle" },
            { "type": "addLog", "text": "队员成功撤离。", "tone": "success" }
          ],
          "failureEffects": [
            { "type": "addCrewCondition", "condition": "light_wound" },
            { "type": "updateCrewStatus", "status": "idle" }
          ]
        },
        {
          "choiceId": "fight",
          "text": "尝试驱赶",
          "tone": "danger",
          "baseSuccessChance": 0.55,
          "dangerStageModifier": -0.08,
          "successEffects": [
            { "type": "addLog", "text": "队员击退了野兽。", "tone": "success" }
          ],
          "failureEffects": [
            { "type": "addCrewCondition", "condition": "heavy_wound" },
            { "type": "updateCrewStatus", "status": "lost" }
          ]
        }
      ],
      "emergency": {
        "firstWaitSeconds": 30,
        "escalationIntervalSeconds": 30,
        "deadlineSeconds": 120,
        "autoResolveResult": "run"
      },
      "resultText": {
        "start": "队员压低声音报告：附近有大型野兽正在靠近。",
        "escalate": "野兽越来越近，队员的声音开始变得急促。",
        "timeout": "队员没有等到指示，只能自行撤离。"
      },
      "tags": ["forest", "danger", "emergency"]
    },
    {
      "eventId": "emergency_mountain_cave_darkness",
      "title": "洞穴低光区域",
      "type": "emergency",
      "priority": 55,
      "scope": "crew",
      "repeatable": true,
      "cooldownSeconds": 1800,
      "trigger": {
        "source": "surveyComplete",
        "tileTypes": ["hill", "mountain"],
        "surveyLevel": "standard"
      },
      "conditions": ["crew.status != lost", "crew.status != dead"],
      "baseChance": 0.08,
      "modifiers": [
        { "condition": "crew.attributes.perception >= 4", "chance": 0.05 }
      ],
      "durationSeconds": 0,
      "effects": [
        { "type": "startEmergency" },
        { "type": "updateCrewStatus", "status": "inEvent" }
      ],
      "choices": [
        {
          "choiceId": "hold_position",
          "text": "原地标记入口，等待光线恢复",
          "tone": "muted",
          "effects": [
            { "type": "updateCrewStatus", "status": "idle" },
            { "type": "addLog", "text": "队员退回洞口并标记了低光区域，未继续深入。", "tone": "muted" }
          ]
        },
        {
          "choiceId": "use_light",
          "text": "使用照明道具继续确认洞内路径",
          "usesItemTag": "light",
          "unavailableHint": "需要可用的照明道具才能安全进入低光区域。",
          "tone": "accent",
          "effects": [
            { "type": "useItemByTag", "itemTag": "light" },
            { "type": "updateCrewStatus", "status": "idle" },
            { "type": "addLog", "text": "照明稳定后，队员确认了洞内可通行路径和湿滑边界。", "tone": "success" }
          ]
        }
      ],
      "emergency": {
        "firstWaitSeconds": 30,
        "escalationIntervalSeconds": 30,
        "deadlineSeconds": 120,
        "autoResolveResult": "hold_position"
      },
      "resultText": {
        "start": "队员报告前方洞穴光线迅速下降，肉眼无法确认地面。",
        "escalate": "通讯里只剩脚下碎石声，队员要求立刻决定是否使用照明。",
        "timeout": "队员放弃深入，沿原路退回洞口。"
      },
      "tags": ["cave", "light", "emergency"]
    },
    {
      "eventId": "emergency_signal_assist_comms",
      "title": "通讯定位偏移",
      "type": "emergency",
      "priority": 50,
      "scope": "crew",
      "repeatable": true,
      "cooldownSeconds": 1800,
      "trigger": {
        "source": "idleTime",
        "tileTypes": ["plain"],
        "minIdleSeconds": 120
      },
      "conditions": ["crew.status != lost", "crew.status != dead"],
      "baseChance": 0.05,
      "modifiers": [],
      "durationSeconds": 0,
      "effects": [
        { "type": "startEmergency" },
        { "type": "updateCrewStatus", "status": "inEvent" }
      ],
      "choices": [
        {
          "choiceId": "wait_for_lock",
          "text": "维持静默，等待通讯台重新锁定",
          "tone": "muted",
          "effects": [
            { "type": "updateCrewStatus", "status": "idle" },
            { "type": "addLog", "text": "队员保持静默，通讯台稍后恢复了基础联络。", "tone": "muted" }
          ]
        },
        {
          "choiceId": "boost_with_signal",
          "text": "使用信号道具辅助定位",
          "usesItemTag": "signal",
          "unavailableHint": "需要可用的信号道具才能辅助通讯定位。",
          "tone": "accent",
          "effects": [
            { "type": "useItemByTag", "itemTag": "signal" },
            { "type": "updateCrewStatus", "status": "idle" },
            { "type": "addLog", "text": "信号辅助后通讯噪声下降，定位坐标被重新校准，并回传了一段额外环境信息。", "tone": "success" }
          ]
        }
      ],
      "emergency": {
        "firstWaitSeconds": 30,
        "escalationIntervalSeconds": 30,
        "deadlineSeconds": 120,
        "autoResolveResult": "wait_for_lock"
      },
      "resultText": {
        "start": "通讯台提示队员定位发生偏移，语音包开始错位。",
        "escalate": "定位误差继续扩大，需要额外信号辅助或等待重新锁定。",
        "timeout": "通讯台自行降级到基础联络，额外信息丢失。"
      },
      "tags": ["signal", "communication", "emergency"]
    }
  ]
}
