{
  "call_templates": [
    {
      "schema_version": "event-program-model-v1",
      "id": "mine_anomaly_report.call.report",
      "version": 1,
      "domain": "mine",
      "event_definition_id": "mine_anomaly_report",
      "node_id": "report",
      "render_context_fields": ["crew_id", "crew_display_name", "tile_id", "event_pressure"],
      "opening_lines": {
        "selection": "best_match",
        "variants": [
          {
            "id": "mine_anomaly_opening_default",
            "text": "{{crew_display_name}} 报告 {{tile_id}} 的矿脉深处传来异常空声。",
            "priority": 0
          }
        ]
      },
      "body_lines": [
        {
          "selection": "first_match",
          "max_lines": 1,
          "variants": [
            {
              "id": "mine_anomaly_body_default",
              "text": "敲击回波不像实心矿体，更像有一段被掏空的裂腔。",
              "priority": 0
            }
          ]
        }
      ],
      "option_lines": {
        "log_anomaly": {
          "selection": "best_match",
          "variants": [
            {
              "id": "mine_anomaly_log_default",
              "text": "记录矿脉异常，采矿流程保持不变。",
              "priority": 0
            }
          ]
        }
      },
      "fallback_order": ["crew_id", "event_pressure", "default"],
      "default_variant_required": true
    }
  ]
}
