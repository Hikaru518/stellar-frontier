{
  "call_templates": [
    {
      "schema_version": "event-program-model-v1",
      "id": "volcanic_ash_trace.call.briefing",
      "version": 1,
      "domain": "desert",
      "event_definition_id": "volcanic_ash_trace",
      "node_id": "ash_trace_call",
      "render_context_fields": ["crew_id", "crew_display_name", "tile_id", "event_pressure"],
      "opening_lines": {
        "selection": "best_match",
        "variants": [
          {
            "id": "ash_opening_default",
            "text": "{{crew_display_name}} 在 {{tile_id}} 发现一道横穿地表的灰色灰线。",
            "priority": 0
          }
        ]
      },
      "body_lines": [
        {
          "selection": "first_match",
          "max_lines": 1,
          "variants": [
            {
              "id": "ash_body_default",
              "text": "风正在抹掉痕迹，需要另一名队员尽快复核。",
              "priority": 0
            }
          ]
        }
      ],
      "option_lines": {
        "assign_probe": {
          "selection": "best_match",
          "variants": [
            {
              "id": "ash_assign_default",
              "text": "创建跨队员调查目标。",
              "priority": 0
            }
          ]
        },
        "seal_sample": {
          "selection": "best_match",
          "variants": [
            {
              "id": "ash_sample_default",
              "text": "封存样本，跳过二次调查。",
              "priority": 0
            }
          ]
        }
      },
      "fallback_order": ["crew_id", "event_pressure", "default"],
      "default_variant_required": true
    }
  ]
}
