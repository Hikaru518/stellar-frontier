{
  "call_templates": [
    {
      "schema_version": "event-program-model-v1",
      "id": "volcanic_ash_trace.call.briefing",
      "version": 1,
      "domain": "desert",
      "event_definition_id": "volcanic_ash_trace",
      "node_id": "ash_trace_call",
      "render_context_fields": ["crew_id", "crew_display_name", "tile_id", "event_pressure"],
      "opening_lines": {
        "selection": "best_match",
        "variants": [
          {
            "id": "ash_opening_default",
            "text": "{{crew_display_name}} found a gray ash line cutting across {{tile_id}}.",
            "priority": 0
          }
        ]
      },
      "body_lines": [
        {
          "selection": "first_match",
          "max_lines": 1,
          "variants": [
            {
              "id": "ash_body_default",
              "text": "It is fading under wind; another crew member can verify it.",
              "priority": 0
            }
          ]
        }
      ],
      "option_lines": {
        "assign_probe": {
          "selection": "best_match",
          "variants": [
            {
              "id": "ash_assign_default",
              "text": "Create a cross-crew survey objective.",
              "priority": 0
            }
          ]
        },
        "seal_sample": {
          "selection": "best_match",
          "variants": [
            {
              "id": "ash_sample_default",
              "text": "Seal a sample and skip the survey.",
              "priority": 0
            }
          ]
        }
      },
      "fallback_order": ["crew_id", "event_pressure", "default"],
      "default_variant_required": true
    }
  ]
}
