      "option_lines": {
        "hold_position": {
          "selection": "best_match",
          "variants": [
            {
              "id": "beast_hold_default",
              "text": "Hold position and stay quiet.",
              "priority": 0
            }
          ]
        },
        "fall_back": {
          "selection": "best_match",
          "variants": [
            {
              "id": "beast_fallback_default",
