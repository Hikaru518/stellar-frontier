{
  "call_templates": [
    {
      "schema_version": "event-program-model-v1",
      "id": "forest_trace_small_camp.call.report",
      "version": 1,
      "domain": "forest",
      "event_definition_id": "forest_trace_small_camp",
      "node_id": "trace_report",
      "render_context_fields": ["crew_id", "crew_display_name", "tile_id", "event_pressure"],
      "opening_lines": {
        "selection": "best_match",
        "variants": [
          {
            "id": "trace_opening_default",
            "text": "{{crew_display_name}} 报告 {{tile_id}} 附近有一处小型营地痕迹。",
            "priority": 0
          }
        ]
      },
      "body_lines": [
        {
          "selection": "first_match",
          "max_lines": 1,
          "variants": [
            {
              "id": "trace_body_default",
              "text": "没有活动迹象，只有冷灰和一根被绑过的树枝。",
              "priority": 0
            }
          ]
        }
      ],
      "option_lines": {
        "mark_camp": {
          "selection": "best_match",
          "variants": [
            {
              "id": "trace_mark_default",
              "text": "标记这处营地痕迹。",
              "priority": 0
            }
          ]
        },
        "note_only": {
          "selection": "best_match",
          "variants": [
            {
              "id": "trace_note_default",
              "text": "记录下来，继续行动。",
              "priority": 0
            }
          ]
        }
      },
      "fallback_order": ["crew_id", "event_pressure", "default"],
      "default_variant_required": true
    },
    {
      "schema_version": "event-program-model-v1",
      "id": "forest_beast_encounter.call.first",
      "version": 1,
      "domain": "forest",
      "event_definition_id": "forest_beast_encounter",
      "node_id": "beast_first_call",
      "render_context_fields": ["crew_id", "crew_display_name", "tile_id", "event_pressure", "crew_conditions"],
      "opening_lines": {
        "selection": "best_match",
        "variants": [
          {
            "id": "beast_first_opening_default",
            "text": "{{crew_display_name}} 压低声音：有个大型生物正在 {{tile_id}} 周围绕行。",
            "priority": 0
          }
        ]
      },
      "body_lines": [
        {
          "selection": "first_match",
          "max_lines": 1,
          "variants": [
            {
              "id": "beast_first_body_default",
              "text": "通讯里传来喘息声，还有湿树枝断裂的声音。",
              "priority": 0
            }
          ]
        }
      ],
      "option_lines": {
        "hold_position": {
          "selection": "best_match",
          "variants": [
            {
              "id": "beast_hold_default",
              "text": "保持位置，降低声响。",
              "priority": 0
            }
          ]
        },
        "fall_back": {
          "selection": "best_match",
          "variants": [
            {
              "id": "beast_fallback_default",
              "text": "立刻后撤。",
              "priority": 0
            }
          ]
        }
      },
      "fallback_order": ["crew_conditions", "event_pressure", "default"],
      "default_variant_required": true
    },
    {
      "schema_version": "event-program-model-v1",
      "id": "forest_beast_encounter.call.followup",
      "version": 1,
      "domain": "forest",
      "event_definition_id": "forest_beast_encounter",
      "node_id": "beast_followup_call",
      "render_context_fields": ["crew_id", "crew_display_name", "tile_id", "event_pressure", "crew_conditions"],
      "opening_lines": {
        "selection": "best_match",
        "variants": [
          {
            "id": "beast_followup_opening_default",
            "text": "{{crew_display_name}} 已经看清角度，但野兽还没有离开。",
            "priority": 0
          }
        ]
      },
      "body_lines": [
        {
          "selection": "first_match",
          "max_lines": 1,
          "variants": [
            {
              "id": "beast_followup_body_default",
              "text": "短促噪声也许能把它赶走。",
              "priority": 0
            }
          ]
        }
      ],
      "option_lines": {
        "drive_off": {
          "selection": "best_match",
          "variants": [
            {
              "id": "beast_drive_default",
              "text": "制造噪声驱离它。",
              "priority": 0
            }
          ]
        },
        "stay_hidden": {
          "selection": "best_match",
          "variants": [
            {
              "id": "beast_hide_default",
              "text": "继续躲藏，等它离开。",
              "priority": 0
            }
          ]
        }
      },
      "fallback_order": ["crew_conditions", "event_pressure", "default"],
      "default_variant_required": true
    }
  ]
