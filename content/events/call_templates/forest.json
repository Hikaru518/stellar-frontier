{
  "call_templates": [
    {
      "schema_version": "event-program-model-v1",
      "id": "forest_trace_small_camp.call.report",
      "version": 1,
      "domain": "forest",
      "event_definition_id": "forest_trace_small_camp",
      "node_id": "trace_report",
      "render_context_fields": ["crew_id", "crew_display_name", "tile_id", "event_pressure"],
      "opening_lines": {
        "selection": "best_match",
        "variants": [
          {
            "id": "trace_opening_default",
            "text": "{{crew_display_name}} 报告 {{tile_id}} 附近有一处小型营地痕迹。",
            "priority": 0
          }
        ]
      },
      "body_lines": [
        {
          "selection": "first_match",
          "max_lines": 1,
          "variants": [
            {
              "id": "trace_body_default",
              "text": "没有活动迹象，只有冷灰和一根被绑过的树枝。",
              "priority": 0
            }
          ]
        }
      ],
      "option_lines": {
        "mark_camp": {
          "selection": "best_match",
          "variants": [
            {
              "id": "trace_mark_default",
              "text": "标记这处营地痕迹。",
              "priority": 0
            }
          ]
        },
        "note_only": {
          "selection": "best_match",
          "variants": [
            {
              "id": "trace_note_default",
              "text": "记录下来，继续行动。",
              "priority": 0
            }
          ]
        }
      },
      "fallback_order": ["crew_id", "event_pressure", "default"],
      "default_variant_required": true
    },
    {
      "schema_version": "event-program-model-v1",
      "id": "forest_beast_emergency.call.report",
      "version": 1,
      "domain": "forest",
      "event_definition_id": "forest_beast_emergency",
      "node_id": "beast_emergency_call",
      "render_context_fields": ["crew_id", "crew_display_name", "tile_id", "event_pressure", "severity", "crew_conditions"],
      "opening_lines": {
        "selection": "best_match",
        "variants": [
          {
            "id": "beast_emergency_opening_default",
            "text": "{{crew_display_name}} 压低声音：大型野兽正在 {{tile_id}} 周围逼近，我需要立刻指令。",
            "priority": 0
          }
        ]
      },
      "body_lines": [
        {
          "selection": "first_match",
          "max_lines": 1,
          "variants": [
            {
              "id": "beast_emergency_body_default",
              "text": "通讯里传来潮湿树枝断裂声，Amy 的呼吸被刻意压得很低。",
              "priority": 0
            }
          ]
        }
      ],
      "option_lines": {
        "evacuate": {
          "selection": "best_match",
          "variants": [
            {
              "id": "beast_evacuate_default",
              "text": "撤离到开阔地。",
              "priority": 0
            }
          ]
        },
        "engage": {
          "selection": "best_match",
          "variants": [
            {
              "id": "beast_engage_default",
              "text": "用随身武器和声响驱赶它。",
              "priority": 0
            }
          ]
        },
        "stay_hidden": {
          "selection": "best_match",
          "variants": [
            {
              "id": "beast_hide_default",
              "text": "继续隐藏，保持安静。",
              "priority": 0
            }
          ]
        }
      },
      "fallback_order": ["crew_conditions", "event_pressure", "default"],
      "default_variant_required": true
    }
  ]
}
