{
  "call_templates": [
    {
      "schema_version": "event-program-model-v1",
      "id": "mainline_medical_pod_survey.call.report",
      "version": 1,
      "domain": "mainline_medical",
      "event_definition_id": "mainline_medical_pod_survey",
      "node_id": "medical_report",
      "render_context_fields": ["crew_id", "crew_display_name", "tile_id", "event_pressure"],
      "opening_lines": { "selection": "best_match", "variants": [{ "id": "medical_pod_opening", "text": "{{crew_display_name}} 打开了废弃医疗舱的残存储格。", "priority": 0 }] },
      "body_lines": [{ "selection": "first_match", "max_lines": 1, "variants": [{ "id": "medical_pod_body", "text": "医疗舱内仍有可用药品，终端中也保存着野外急救流程。当前队员取得 medicine 并学习 knows_field_first_aid。", "priority": 0 }] }],
      "option_lines": { "collect": { "selection": "best_match", "variants": [{ "id": "medical_pod_collect", "text": "收集药品并保存医疗文档。", "priority": 0 }] } },
      "fallback_order": ["crew_id", "event_pressure", "default"],
      "default_variant_required": true
    },
    {
      "schema_version": "event-program-model-v1",
      "id": "mainline_medical_docs_repeat_learning.call.learn",
      "version": 1,
      "domain": "mainline_medical",
