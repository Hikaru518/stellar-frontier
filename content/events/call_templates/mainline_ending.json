      "body_lines": [{ "selection": "first_match", "max_lines": 1, "variants": [{ "id": "ending_body", "text": "返航需按顺序完成三步：先用 warp_pod_repair_kit 修复仓体，再注入 alien_slime_fuel，最后输入 warp_coordinates 并确认所有可通讯可行动队员都在 4-4。", "priority": 0 }] }],
      "option_lines": {
        "repair_hull": { "selection": "best_match", "variants": [{ "id": "ending_hull", "text": "修复折跃仓仓体。", "priority": 0 }] },
