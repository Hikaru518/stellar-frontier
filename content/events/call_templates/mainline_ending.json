        "launch_home": { "selection": "best_match", "variants": [{ "id": "ending_launch", "text": "输入折跃坐标并启动返航。", "priority": 0 }] },
        "inspect": { "selection": "best_match", "variants": [{ "id": "ending_inspect", "text": "检查终局需求。", "priority": 0 }] }
      },
      "fallback_order": ["crew_id", "event_pressure", "default"],
