{
  "call_templates": [
    {
      "schema_version": "event-program-model-v1",
      "id": "garry_mine_anomaly_report.call.report",
      "version": 1,
      "domain": "mountain",
      "event_definition_id": "garry_mine_anomaly_report",
      "node_id": "mine_anomaly_call",
      "render_context_fields": ["crew_id", "crew_display_name", "tile_id", "event_pressure"],
      "opening_lines": {
        "selection": "best_match",
        "variants": [
          {
            "id": "mine_anomaly_opening_default",
            "text": "{{crew_display_name}} 报告 {{tile_id}} 的矿床下方传来空洞回声。",
            "priority": 0
          }
        ]
      },
      "body_lines": [
        {
          "selection": "first_match",
          "max_lines": 1,
          "variants": [
            {
              "id": "mine_anomaly_body_default",
              "text": "温度计先升后降，像岩层刚刚吐出一口气。",
              "priority": 0
            }
          ]
        }
      ],
      "option_lines": {
        "mark_anomaly": {
          "selection": "best_match",
          "variants": [
            {
              "id": "mine_anomaly_mark_default",
              "text": "标记异常，交给工程复核。",
              "priority": 0
            }
          ]
        },
        "log_reading": {
          "selection": "best_match",
          "variants": [
            {
              "id": "mine_anomaly_log_default",
              "text": "记录读数，暂时保持矿床静默。",
              "priority": 0
            }
          ]
        }
      },
      "fallback_order": ["crew_id", "event_pressure", "default"],
      "default_variant_required": true
    }
  ]
}
