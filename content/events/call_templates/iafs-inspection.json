    { "schema_version": "event-program-model-v1", "id": "iafs_crash_site_survey_reveal.call.report", "version": 1, "domain": "iafs-inspection", "event_definition_id": "iafs_crash_site_survey_reveal", "node_id": "report", "render_context_fields": ["crew_id"], "opening_lines": { "selection": "best_match", "variants": [{ "id": "opening", "text": "我把坠毁点周围大致看了一圈。", "priority": 0 }] }, "body_lines": [{ "selection": "first_match", "variants": [{ "id": "body", "text": "这里还有几套能辨认出来的关键设施，发电机、维生装置和穿梭机核心都还在，只是现在都散在撞击坑边上。", "priority": 0 }] }], "option_lines": { "ack": { "selection": "best_match", "variants": [{ "id": "ack", "text": "标记这些可用设施。", "priority": 0 }] } }, "fallback_order": ["default"], "default_variant_required": true },
