{
  "call_templates": [
    { "schema_version": "event-program-model-v1", "id": "iafs_opening_mike_crash_call.call.crash_report", "version": 1, "domain": "iafs-inspection", "event_definition_id": "iafs_opening_mike_crash_call", "node_id": "crash_report", "render_context_fields": ["crew_id"], "opening_lines": { "selection": "best_match", "variants": [{ "id": "opening", "text": "这里是 Mike。信号很差，但我听得到你们。", "priority": 0 }] }, "body_lines": [{ "selection": "first_match", "variants": [{ "id": "impact", "text": "坠毁前我看见右舷外面闪了一下，像一层白色的火从船壳上擦过去。醒来以后，主舱断成两截，外面全是散开的箱子和烧黑的金属片。", "priority": 0 }] }, { "selection": "first_match", "variants": [{ "id": "home", "text": "我不知道这里是哪儿。我只想确认一件事：你们会带我回家，对吗？", "priority": 0 }] }], "option_lines": { "promise_return_home": { "selection": "best_match", "variants": [{ "id": "promise_return_home", "text": "我们会带你回家。先稳住，把眼前的情况说清楚。", "priority": 0 }] }, "keep_him_grounded": { "selection": "best_match", "variants": [{ "id": "keep_him_grounded", "text": "会的。先活下来，我们一步一步把回家的路找出来。", "priority": 0 }] } }, "fallback_order": ["default"], "default_variant_required": true },
    { "schema_version": "event-program-model-v1", "id": "iafs_opening_mike_crash_call.call.facilities_prompt", "version": 1, "domain": "iafs-inspection", "event_definition_id": "iafs_opening_mike_crash_call", "node_id": "facilities_prompt", "render_context_fields": ["crew_id"], "opening_lines": { "selection": "best_match", "variants": [{ "id": "opening", "text": "好。我还在坠毁点附近，能看到几块还没完全冷下来的舱段。", "priority": 0 }] }, "body_lines": [{ "selection": "first_match", "variants": [{ "id": "body", "text": "主推进不可能再点火了，但有些设备没有被炸散。也许还能从船上找出能用的设施，至少确认发电、维生和核心舱段的状态。", "priority": 0 }] }], "option_lines": { "check_usable_facilities": { "selection": "best_match", "variants": [{ "id": "check_usable_facilities", "text": "让我们先看看手头的情况如何，飞船上还有能够使用的设施吗？", "priority": 0 }] }, "inventory_ship_systems": { "selection": "best_match", "variants": [{ "id": "inventory_ship_systems", "text": "先把飞船还能辨认的设施列出来，我们从可用部分开始。", "priority": 0 }] } }, "fallback_order": ["default"], "default_variant_required": true },
    { "schema_version": "event-program-model-v1", "id": "iafs_opening_mike_crash_call.call.cargo_prompt", "version": 1, "domain": "iafs-inspection", "event_definition_id": "iafs_opening_mike_crash_call", "node_id": "cargo_prompt", "render_context_fields": ["crew_id"], "opening_lines": { "selection": "best_match", "variants": [{ "id": "opening", "text": "我能看见一些货物散在外面。", "priority": 0 }] }, "body_lines": [{ "selection": "first_match", "variants": [{ "id": "body", "text": "有的箱子摔开了，有的还卡在外壳下面。现在天色和烟都不帮忙，但如果派人搜一圈，应该能找回一点能用的东西。", "priority": 0 }] }], "option_lines": { "search_scattered_cargo": { "selection": "best_match", "variants": [{ "id": "search_scattered_cargo", "text": "有一些货物掉在了外面，可能派人去搜寻一番。", "priority": 0 }] }, "mark_external_cargo": { "selection": "best_match", "variants": [{ "id": "mark_external_cargo", "text": "先标记散落货物的位置，等确认安全后安排搜寻。", "priority": 0 }] } }, "fallback_order": ["default"], "default_variant_required": true },
    { "schema_version": "event-program-model-v1", "id": "iafs_opening_mike_crash_call.call.route_prompt", "version": 1, "domain": "iafs-inspection", "event_definition_id": "iafs_opening_mike_crash_call", "node_id": "route_prompt", "render_context_fields": ["crew_id"], "opening_lines": { "selection": "best_match", "variants": [{ "id": "opening", "text": "如果船飞不起来，我们就不能只盯着残骸。", "priority": 0 }] }, "body_lines": [{ "selection": "first_match", "variants": [{ "id": "body", "text": "坠毁区外面有山脊和陌生的光，我还听见过像风铃一样的回声。也许只是金属在冷却，也许这里有人。", "priority": 0 }] }], "option_lines": { "find_exit_route": { "selection": "best_match", "variants": [{ "id": "find_exit_route", "text": "看样子飞船是没办法重新启航了，得让人寻找一下出去的路。", "priority": 0 }] }, "seek_local_contact": { "selection": "best_match", "variants": [{ "id": "seek_local_contact", "text": "我们要找离开这里的办法，也看看能不能找到一些当地居民帮忙。", "priority": 0 }] } }, "fallback_order": ["default"], "default_variant_required": true },
