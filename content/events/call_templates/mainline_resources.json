      "body_lines": [{ "selection": "first_match", "max_lines": 1, "variants": [{ "id": "old_ship_body", "text": "失效驾驶舱仍保存着可用折跃坐标。确认后 warp_coordinates 会进入当前队员个人背包，并设置 warp_coordinates_found。", "priority": 0 }] }],
