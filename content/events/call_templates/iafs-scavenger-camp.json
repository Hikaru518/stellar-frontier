      },
      "fallback_order": ["default"],
      "default_variant_required": true
    },
    {
      "schema_version": "event-program-model-v1",
      "id": "iafs_scavenger_heir_chief_invitation.call.decline_chief_reply",
      "version": 1,
      "domain": "iafs-scavenger-camp",
      "event_definition_id": "iafs_scavenger_heir_chief_invitation",
