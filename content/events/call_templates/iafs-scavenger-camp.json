    {
      "schema_version": "event-program-model-v1",
      "id": "iafs_scavenger_sentry_line_contact.call.sentry_challenge",
      "version": 3,
      "domain": "iafs-scavenger-camp",
      "event_definition_id": "iafs_scavenger_sentry_line_contact",
      "node_id": "sentry_challenge",
      "render_context_fields": ["crew_id", "crew_display_name"],
      "opening_lines": {
        "selection": "best_match",
        "variants": [
          {
            "id": "sentry_report",
            "text": "{{crew_display_name}}：指挥官，我到他们外线了。外面有一个哨卫，正从废料挡板附近巡逻。",
            "priority": 0
          }
        ]
      },
      "body_lines": [
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "sentry_look",
              "text": "{{crew_display_name}}：他裹着灰白包巾，戴护目镜，旧隔热布外套下面露着磨白的护片。手边有警铃绳，腰侧挂着短柄钩刀，背后还有一截管枪式自制武器，但不像正规军火力。",
              "priority": 0
            }
          ]
        },
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "sentry_approach",
              "text": "{{crew_display_name}}：先别急，我看得见他的手，问题还不大。他不是冲过来，只是在把我压在线外。",
              "priority": 0
            }
          ]
        },
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "sentry_hidden_startle",
              "text": "{{crew_display_name}}：不要紧指挥官，我现在隐藏得很好。啊……！",
              "priority": 0
            }
          ]
        },
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "crew_signal_drop",
              "text": "（{{crew_display_name}}的声音突然消失了，但你还听得到呼吸声，然后是碰撞的声音）",
              "priority": 0
            }
          ]
        },
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "stranger_voice_interrupt",
              "text": "（通讯另一端突然传来另一个陌生男子的声音，是命令式的语气）",
              "priority": 0
            }
          ]
        },
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "stranger_challenge",
              "text": "陌生男子：站住！线外说话，手别乱动。报名字、来路、找谁。少答一样，我就当你是麻烦。",
              "priority": 0
            }
          ]
        }
      ],
      "option_lines": {
        "opt_observe": {
          "selection": "best_match",
          "variants": [
            {
              "id": "observe",
              "text": "暂不回应，保持隐蔽并监听线内动静。",
              "priority": 0
            }
          ]
        },
        "opt_threaten": {
          "selection": "best_match",
          "variants": [
            {
              "id": "threaten",
              "text": "强硬压制哨卫，逼他松开警铃绳。",
              "priority": 0
            }
          ]
        },
        "opt_negotiate": {
          "selection": "best_match",
          "variants": [
            {
              "id": "negotiate",
              "text": "稳住局面，只透露最低限度来意。",
              "priority": 0
            }
          ]
        },
        "opt_chat": {
          "selection": "best_match",
          "variants": [
            {
              "id": "chat",
              "text": "用闲聊试探哨卫，套出他们最近的麻烦。",
              "priority": 0
            }
          ]
        },
        "opt_heir_handkerchief": {
          "selection": "best_match",
          "variants": [
            {
              "id": "heir_handkerchief",
              "text": "展示自己的家徽手帕。",
              "priority": 0
            }
          ]
        }
      },
      "fallback_order": ["default"],
      "default_variant_required": true
    },
    {
