      },
      "body_lines": [
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "choice_remains",
              "text": "{{crew_display_name}}：邀请还在。要么进去见村长，要么我继续留在线外。",
              "priority": 0
            }
          ]
        }
      ],
      "option_lines": {
        "ack_sentry_doubts_missed": {
          "selection": "best_match",
          "variants": [
            {
              "id": "ack_sentry_doubts_missed",
              "text": "回到村长邀请的选择。",
              "priority": 0
            }
          ]
        }
      },
      "fallback_order": ["default"],
      "default_variant_required": true
    },
    {
      "schema_version": "event-program-model-v1",
