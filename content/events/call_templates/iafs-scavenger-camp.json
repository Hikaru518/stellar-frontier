{
  "call_templates": [
    {
      "schema_version": "event-program-model-v1",
      "id": "iafs_scavenger_camp_outer_discovery.call.outer_report",
      "version": 1,
      "domain": "iafs-scavenger-camp",
      "event_definition_id": "iafs_scavenger_camp_outer_discovery",
      "node_id": "outer_report",
      "render_context_fields": ["crew_id", "crew_display_name"],
      "opening_lines": {
        "selection": "best_match",
        "variants": [
          {
            "id": "outer_report_settlement",
            "text": "{{crew_display_name}}：指挥官，我在前面看见一个村落。不是正式殖民点，更像拾荒者住出来的地方。",
            "priority": 0
          }
        ]
      },
      "body_lines": [
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "outer_report_buildings",
              "text": "{{crew_display_name}}：房子很低，用旧舱板、岩片和遮风布拼起来，棚顶压着废管和缆索。能看见几堆整理过的零件、燃料罐和布包，像是能拿来交易的物资。",
              "priority": 0
            }
          ]
        },
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "outer_report_people",
              "text": "{{crew_display_name}}：外面有人走动，衣服都很旧，补丁一层压一层。他们看起来穷，但不是乱散的流民，入口、货堆和帐篷之间有人在放哨。",
              "priority": 0
            }
          ]
        },
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "outer_report_request",
              "text": "{{crew_display_name}}：我还没靠太近。你决定，是继续接近，还是让我先停在这里看一会儿？",
              "priority": 0
            }
          ]
        }
      ],
      "option_lines": {
        "opt_approach": {
          "selection": "best_match",
          "variants": [
            {
              "id": "approach",
              "text": "指示队员继续靠近外线，但不要进入营地。",
              "priority": 0
            }
          ]
        },
        "opt_standby": {
          "selection": "best_match",
          "variants": [
            {
              "id": "standby",
              "text": "让队员保持距离，先停下观察营地动向。",
              "priority": 0
            }
          ]
        }
      },
      "fallback_order": ["default"],
      "default_variant_required": true
    },
    {
      "schema_version": "event-program-model-v1",
      "id": "iafs_scavenger_heir_chief_invitation.call.chief_invitation",
      "version": 1,
      "domain": "iafs-scavenger-camp",
      "event_definition_id": "iafs_scavenger_heir_chief_invitation",
      "node_id": "chief_invitation",
      "render_context_fields": ["crew_id", "crew_display_name"],
      "opening_lines": {
        "selection": "best_match",
        "variants": [
          {
            "id": "chief_invitation_opening",
            "text": "（两分钟后，频道里传来另一个更年长的声音）陌生人：带家徽的人，村长愿意见你。",
            "priority": 0
          }
        ]
      },
      "body_lines": [
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "sentry_waits",
              "text": "{{crew_display_name}}：刚才那个哨卫还在旁边。他没有再催，但一直盯着我的手和装备。",
              "priority": 0
            }
          ]
        },
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "chief_invite_terms",
              "text": "陌生人：你可以进来，也可以继续站在线外。进来就按我们的规矩走，不要把武器端在胸前。",
              "priority": 0
            }
          ]
        }
      ],
      "option_lines": {
        "opt_accept_chief": {
          "selection": "best_match",
          "variants": [
            {
              "id": "accept_chief",
              "text": "同意见村长。",
              "priority": 0
            }
          ]
        },
        "opt_read_sentry": {
          "selection": "best_match",
          "variants": [
            {
              "id": "read_sentry",
              "text": "观察哨兵的迟疑。",
              "priority": 0
            }
          ]
        },
        "opt_decline_chief": {
          "selection": "best_match",
          "variants": [
            {
              "id": "decline_chief",
              "text": "拒绝见村长，原地待命。",
              "priority": 0
            }
          ]
        }
      },
      "fallback_order": ["default"],
      "default_variant_required": true
    },
    {
      "schema_version": "event-program-model-v1",
      "id": "iafs_scavenger_heir_chief_invitation.call.sentry_doubts_read_reply",
      "version": 1,
      "domain": "iafs-scavenger-camp",
      "event_definition_id": "iafs_scavenger_heir_chief_invitation",
      "node_id": "sentry_doubts_read_reply",
      "render_context_fields": ["crew_id", "crew_display_name"],
      "opening_lines": {
        "selection": "best_match",
        "variants": [
          {
            "id": "doubts_read",
            "text": "{{crew_display_name}}：我看出来了。哨卫怕的不是家徽，是我们身上的武器和外来装备。",
            "priority": 0
          }
        ]
      },
      "body_lines": [
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "shortage_read",
              "text": "{{crew_display_name}}：他们盯着弹匣、滤芯和保温层看的时间太久。这里明显缺物资，尤其缺能防寒和维持装备的东西。",
              "priority": 0
            }
          ]
        }
      ],
      "option_lines": {
        "ack_sentry_doubts_read": {
          "selection": "best_match",
          "variants": [
            {
              "id": "ack_sentry_doubts_read",
              "text": "带着这条判断重新决定是否见村长。",
              "priority": 0
            }
          ]
        }
      },
      "fallback_order": ["default"],
      "default_variant_required": true
    },
    {
      "schema_version": "event-program-model-v1",
      "id": "iafs_scavenger_heir_chief_invitation.call.sentry_doubts_missed_reply",
      "version": 1,
      "domain": "iafs-scavenger-camp",
      "event_definition_id": "iafs_scavenger_heir_chief_invitation",
      "node_id": "sentry_doubts_missed_reply",
      "render_context_fields": ["crew_id", "crew_display_name"],
      "opening_lines": {
        "selection": "best_match",
        "variants": [
