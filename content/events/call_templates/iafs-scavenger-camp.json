{
  "call_templates": [
    {
      "schema_version": "event-program-model-v1",
      "id": "iafs_scavenger_camp_outer_discovery.call.outer_report",
      "version": 1,
      "domain": "iafs-scavenger-camp",
      "event_definition_id": "iafs_scavenger_camp_outer_discovery",
      "node_id": "outer_report",
      "render_context_fields": ["crew_id"],
      "opening_lines": {
        "selection": "best_match",
        "variants": [
          {
            "id": "outer_report_settlement",
            "text": "指挥官，我在前面看见一个村落。不是正式殖民点，更像拾荒者住出来的地方。",
            "priority": 0
          }
        ]
      },
      "body_lines": [
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "outer_report_buildings",
              "text": "房子很低，用旧舱板、岩片和遮风布拼起来，棚顶压着废管和缆索。能看见几堆整理过的零件、燃料罐和布包，像是能拿来交易的物资。",
              "priority": 0
            }
          ]
        },
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "outer_report_people",
              "text": "外面有人走动，衣服都很旧，补丁一层压一层。他们看起来穷，但不是乱散的流民，入口、货堆和帐篷之间有人在放哨。",
              "priority": 0
            }
          ]
        },
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "outer_report_request",
              "text": "我还没靠太近。你决定，是继续接近，还是让我先停在这里看一会儿？",
              "priority": 0
            }
          ]
        }
      ],
      "option_lines": {
        "opt_approach": {
          "selection": "best_match",
          "variants": [
            {
              "id": "approach",
              "text": "继续接近。别进营地，先靠到他们外线能喊话的位置。",
              "priority": 0
            }
          ]
        },
        "opt_standby": {
          "selection": "best_match",
          "variants": [
            {
              "id": "standby",
              "text": "先别靠近。停在原地，继续观察他们的动静。",
              "priority": 0
            }
          ]
        }
      },
      "fallback_order": ["default"],
      "default_variant_required": true
    },
    {
      "schema_version": "event-program-model-v1",
      "id": "iafs_scavenger_sentry_line_contact.call.sentry_challenge",
      "version": 2,
      "domain": "iafs-scavenger-camp",
      "event_definition_id": "iafs_scavenger_sentry_line_contact",
      "node_id": "sentry_challenge",
      "render_context_fields": ["crew_id"],
      "opening_lines": {
        "selection": "best_match",
        "variants": [
          {
            "id": "sentry_report",
            "text": "指挥官，我到他们外线了。外面有一个哨卫，正从废料挡板附近巡逻。",
            "priority": 0
          }
        ]
      },
      "body_lines": [
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "sentry_look",
              "text": "他裹着灰白包巾，戴护目镜，旧隔热布外套下面露着磨白的护片。手边有警铃绳，腰侧挂着短柄钩刀，背后还有一截管枪式自制武器，但不像正规军火力。",
              "priority": 0
            }
          ]
        },
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "sentry_approach",
              "text": "先别急，我看得见他的手，问题还不大。他不是冲过来，只是在把我压在线外。",
              "priority": 0
            }
          ]
        },
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "sentry_hidden_startle",
              "text": "不要紧指挥官，我现在隐藏地很好。啊……！",
              "priority": 0
            }
          ]
        },
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "white_noise_interrupt",
              "text": "（通讯另一端突然传来另一个陌生男子的声音，是命令式的语气）站住！线外说话，手别乱动。报名字、来路、找谁。少答一样，我就当你是麻烦。",
              "priority": 0
            }
          ]
        }
      ],
      "option_lines": {
        "opt_observe": {
          "selection": "best_match",
          "variants": [
            {
              "id": "observe",
              "text": "先不回答，停在线外，侧耳分辨哨站里面的动静。",
              "priority": 0
            }
          ]
        },
        "opt_threaten": {
          "selection": "best_match",
          "variants": [
            {
              "id": "threaten",
              "text": "把警铃绳松开。我们来问路，不是来求你开门。你要拿“麻烦”吓人，我保证第一个麻烦就落在你这条线上。",
              "priority": 0
            }
          ]
        },
        "opt_negotiate": {
          "selection": "best_match",
          "variants": [
            {
              "id": "negotiate",
              "text": "我们没有敌意。我叫……从附近过来。想找能问路、交易，或者交换情报的人。",
              "priority": 0
            }
          ]
        },
        "opt_chat": {
          "selection": "best_match",
          "variants": [
            {
              "id": "chat",
              "text": "你这套问法很熟。最近来找麻烦的人很多，还是今天特别不想见客？",
              "priority": 0
            }
          ]
        }
      },
      "fallback_order": ["default"],
      "default_variant_required": true
    },
    {
      "schema_version": "event-program-model-v1",
      "id": "iafs_scavenger_sentry_line_contact.call.observe_eavesdrop",
      "version": 1,
      "domain": "iafs-scavenger-camp",
      "event_definition_id": "iafs_scavenger_sentry_line_contact",
      "node_id": "observe_eavesdrop",
      "render_context_fields": ["crew_id"],
      "opening_lines": {
        "selection": "best_match",
        "variants": [
          {
            "id": "listen_first",
            "text": "我先没回话。线里有声音，压得很低，不像是在吵我，更像是在吵里面的事。",
            "priority": 0
          }
        ]
      },
      "body_lines": [
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "frostbay_search",
              "text": "有人说：霜湾的人不能再留在后帐，巡查队今天会搜到边线。",
              "priority": 0
            }
          ]
        },
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "furnace_reply",
              "text": "另一个人回得更急：交出去也是死，烬炉的人不会认账。",
              "priority": 0
            }
          ]
        },
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "caught_between",
              "text": "他们像是夹在两拨人中间，不敢让外线开，也不敢把里面的人推出去。",
              "priority": 0
            }
          ]
        }
      ],
      "option_lines": {
        "ack_observe": {
          "selection": "best_match",
          "variants": [
            {
              "id": "ack_observe",
              "text": "继续保持距离，把听到的记下来。",
              "priority": 0
            }
          ]
        }
      },
      "fallback_order": ["default"],
      "default_variant_required": true
    },
    {
      "schema_version": "event-program-model-v1",
      "id": "iafs_scavenger_sentry_line_contact.call.threaten_backlash",
      "version": 1,
      "domain": "iafs-scavenger-camp",
      "event_definition_id": "iafs_scavenger_sentry_line_contact",
      "node_id": "threaten_backlash",
      "render_context_fields": ["crew_id"],
      "opening_lines": {
        "selection": "best_match",
        "variants": [
          {
            "id": "threat_answered",
            "text": "我把话压回去了。哨卫没退，他的手碰了一下警铃绳，里面马上有人压低声音。",
            "priority": 0
          }
        ]
      },
      "body_lines": [
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "line_pressure",
              "text": "有个声音说：那人是来压线的。",
              "priority": 0
            }
          ]
        },
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "cut_signal",
              "text": "另一个声音更近：别让这路信号继续往外传。",
              "priority": 0
            }
          ]
        },
        {
          "selection": "first_match",
          "variants": [
            {
              "id": "static_rise",
              "text": "等等，通讯噪声在抬高。我还看得见外线，但信号在被压——指挥官，如果你听得到，别让其他人直接靠近——",
              "priority": 0
            }
          ]
        }
      ],
      "option_lines": {
        "ack_threaten": {
          "selection": "best_match",
          "variants": [
            {
              "id": "ack_threaten",
              "text": "继续呼叫，确认队员状态。",
              "priority": 0
            }
          ]
        }
      },
      "fallback_order": ["default"],
      "default_variant_required": true
    }
  ]
}
