{
  "event_definitions": [
    {
      "schema_version": "event-program-model-v1",
      "id": "mainline_crash_site_survey_chain",
      "version": 1,
      "domain": "mainline_crash_site",
      "title": "坠毁点连续调查",
      "summary": "坠毁点前三次调查依次提供基础物资与主目标、雷达方向线索、维修技术文档。",
      "tags": ["mainline", "crash_site", "survey_chain"],
      "status": "approved",
      "trigger": {
        "type": "action_complete",
        "required_context": ["crew_id", "tile_id", "action_id"],
        "conditions": [
          { "type": "handler_condition", "handler_type": "trigger_context_value_equals", "params": { "field": "payload.action_type", "value": "survey" } },
          { "type": "handler_condition", "handler_type": "trigger_context_value_equals", "params": { "field": "tile_id", "value": "4-4" } },
          {
            "type": "any_of",
            "conditions": [
              { "type": "handler_condition", "handler_type": "trigger_context_value_equals", "params": { "field": "payload.object_id", "value": "mainline-damaged-warp-pod" } },
              { "type": "handler_condition", "handler_type": "trigger_context_value_equals", "params": { "field": "payload.object_id", "value": "mainline-repair-docs" } }
            ]
          }
        ]
      },
      "candidate_selection": { "priority": 80, "weight": 1, "mutex_group": null, "max_instances_per_trigger": 1, "requires_blocking_slot": false },
      "repeat_policy": { "scope": "world", "max_trigger_count": null, "cooldown_seconds": 0, "history_key_template": "mainline_crash_site_survey_chain", "allow_while_active": false },
      "event_graph": {
        "entry_node_id": "increment_survey_count",
        "nodes": [
          { "id": "increment_survey_count", "type": "log_only", "title": "记录坠毁点调查次数", "event_log_template_id": "crash_site_survey_counter_log", "effect_refs": ["increment_crash_site_survey_count"], "next_node_id": "select_survey_result", "blocking": { "occupies_crew_action": false, "occupies_communication": false, "blocking_key_template": null } },
          {
            "id": "select_survey_result",
            "type": "check",
            "title": "选择坠毁点调查结果",
            "branches": [
              { "id": "first_survey", "conditions": [{ "type": "compare_field", "target": { "type": "world_flags" }, "field": "crash_site_survey_count.value", "op": "equals", "value": 1 }], "next_node_id": "first_report", "effect_refs": ["first_survey_rewards"] },
              { "id": "second_survey", "conditions": [{ "type": "compare_field", "target": { "type": "world_flags" }, "field": "crash_site_survey_count.value", "op": "equals", "value": 2 }], "next_node_id": "radar_report", "effect_refs": ["radar_survey_rewards"] },
              { "id": "third_or_later_survey", "conditions": [{ "type": "compare_field", "target": { "type": "world_flags" }, "field": "crash_site_survey_count.value", "op": "gte", "value": 3 }], "next_node_id": "repair_docs_report", "effect_refs": ["repair_docs_rewards"] }
            ],
            "default_next_node_id": "repair_docs_report",
            "evaluation_order": "first_match",
            "blocking": { "occupies_crew_action": false, "occupies_communication": false, "blocking_key_template": null }
          },
          { "id": "first_report", "type": "call", "title": "报告返航主目标", "call_template_id": "mainline_crash_site_survey_chain.call.first", "speaker_crew_ref": { "type": "primary_crew" }, "urgency": "normal", "delivery": "queued_message", "options": [{ "id": "ack", "is_default": true }], "option_node_mapping": { "ack": "first_end" }, "blocking": { "occupies_crew_action": false, "occupies_communication": true, "blocking_key_template": null }, "expires_in_seconds": 240 },
          { "id": "radar_report", "type": "call", "title": "报告雷达方向线索", "call_template_id": "mainline_crash_site_survey_chain.call.radar", "speaker_crew_ref": { "type": "primary_crew" }, "urgency": "normal", "delivery": "queued_message", "options": [{ "id": "ack", "is_default": true }], "option_node_mapping": { "ack": "radar_end" }, "blocking": { "occupies_crew_action": false, "occupies_communication": true, "blocking_key_template": null }, "expires_in_seconds": 240 },
          { "id": "repair_docs_report", "type": "call", "title": "报告维修技术文档", "call_template_id": "mainline_crash_site_survey_chain.call.repair_docs", "speaker_crew_ref": { "type": "primary_crew" }, "urgency": "normal", "delivery": "queued_message", "options": [{ "id": "ack", "is_default": true }], "option_node_mapping": { "ack": "repair_docs_end" }, "blocking": { "occupies_crew_action": false, "occupies_communication": true, "blocking_key_template": null }, "expires_in_seconds": 240 },
          { "id": "first_end", "type": "end", "title": "主目标已建立", "resolution": "resolved", "result_key": "main_objective_started", "event_log_template_id": "main_objective_started_log", "history_writes": [{ "key_template": "mainline_crash_site:first_survey", "scope": "world", "value": "main_objective_started" }], "blocking": { "occupies_crew_action": false, "occupies_communication": false, "blocking_key_template": null }, "cleanup_policy": { "release_blocking_claims": true, "delete_active_calls": true, "keep_player_summary": true } },
          { "id": "radar_end", "type": "end", "title": "雷达线索已记录", "resolution": "resolved", "result_key": "radar_clues_found", "event_log_template_id": "radar_clues_found_log", "history_writes": [{ "key_template": "mainline_crash_site:radar_survey", "scope": "world", "value": "radar_clues_found" }], "blocking": { "occupies_crew_action": false, "occupies_communication": false, "blocking_key_template": null }, "cleanup_policy": { "release_blocking_claims": true, "delete_active_calls": true, "keep_player_summary": true } },
          { "id": "repair_docs_end", "type": "end", "title": "维修技术已学习", "resolution": "resolved", "result_key": "repair_docs_available", "event_log_template_id": "repair_docs_available_log", "history_writes": [{ "key_template": "mainline_crash_site:repair_docs", "scope": "world", "value": "repair_docs_available" }], "blocking": { "occupies_crew_action": false, "occupies_communication": false, "blocking_key_template": null }, "cleanup_policy": { "release_blocking_claims": true, "delete_active_calls": true, "keep_player_summary": true } }
        ],
        "edges": [],
        "terminal_node_ids": ["first_end", "radar_end", "repair_docs_end"],
        "graph_rules": { "acyclic": true, "max_active_nodes": 1, "allow_parallel_nodes": false }
      },
      "effect_groups": [
        { "id": "increment_crash_site_survey_count", "effects": [{ "id": "crash_site_survey_counter", "type": "increment_world_counter", "target": { "type": "world_flags" }, "params": { "key": "crash_site_survey_count", "amount": 1, "tags": ["mainline", "crash_site"] }, "failure_policy": "fail_event", "record_policy": { "write_event_log": false, "write_world_history": false } }] },
        {
          "id": "first_survey_rewards",
          "effects": [
          { "id": "first_ration_reward", "type": "add_item", "target": { "type": "crew_inventory" }, "params": { "item_id": "ration", "quantity": 3 }, "failure_policy": "fail_event", "record_policy": { "write_event_log": false, "write_world_history": false } },
          { "id": "first_basic_tool_reward", "type": "add_item", "target": { "type": "crew_inventory" }, "params": { "item_id": "basic_tool", "quantity": 1 }, "failure_policy": "fail_event", "record_policy": { "write_event_log": false, "write_world_history": false } },
          { "id": "first_signal_flare_reward", "type": "add_item", "target": { "type": "crew_inventory" }, "params": { "item_id": "signal_flare", "quantity": 1 }, "failure_policy": "fail_event", "record_policy": { "write_event_log": false, "write_world_history": false } },
            { "id": "main_objective_flag", "type": "set_world_flag", "target": { "type": "world_flags" }, "params": { "key": "main_objective_return_home_known", "value": true, "tags": ["mainline", "objective"] }, "failure_policy": "fail_event", "record_policy": { "write_event_log": false, "write_world_history": false } },
            { "id": "reveal_warp_pod", "type": "update_tile_state", "target": { "type": "event_tile" }, "params": { "object_id": "mainline-damaged-warp-pod", "revealed": true }, "failure_policy": "skip_effect", "record_policy": { "write_event_log": false, "write_world_history": false } },
            { "id": "main_objective_log_effect", "type": "add_event_log", "target": { "type": "event_log" }, "params": { "summary": "坠毁点调查确认折跃仓受损，返航主目标建立：修复仓体、取得燃料与坐标。", "importance": "major", "visibility": "player_visible", "result_key": "main_objective_started" }, "failure_policy": "fail_event", "record_policy": { "write_event_log": false, "write_world_history": false } }
          ]
        },
        {
          "id": "radar_survey_rewards",
          "effects": [
            { "id": "radar_clues_flag", "type": "set_world_flag", "target": { "type": "world_flags" }, "params": { "key": "crash_site_radar_clues_found", "value": true, "tags": ["mainline", "radar"] }, "failure_policy": "fail_event", "record_policy": { "write_event_log": false, "write_world_history": false } },
            { "id": "reveal_village_tile", "type": "set_discovery_state", "target": { "type": "tile_id", "id": "2-4" }, "params": { "state": "discovered" }, "failure_policy": "skip_effect", "record_policy": { "write_event_log": false, "write_world_history": false } },
            { "id": "reveal_old_ship_tile", "type": "set_discovery_state", "target": { "type": "tile_id", "id": "4-8" }, "params": { "state": "discovered" }, "failure_policy": "skip_effect", "record_policy": { "write_event_log": false, "write_world_history": false } },
            { "id": "reveal_volcano_tile", "type": "set_discovery_state", "target": { "type": "tile_id", "id": "8-5" }, "params": { "state": "discovered" }, "failure_policy": "skip_effect", "record_policy": { "write_event_log": false, "write_world_history": false } },
            { "id": "reveal_medical_tile", "type": "set_discovery_state", "target": { "type": "tile_id", "id": "4-1" }, "params": { "state": "discovered" }, "failure_policy": "skip_effect", "record_policy": { "write_event_log": false, "write_world_history": false } },
            { "id": "radar_clues_log_effect", "type": "add_event_log", "target": { "type": "event_log" }, "params": { "summary": "基础雷达给出稳定方向：北侧生命迹象指向外星村落，东侧旧金属反应指向旧飞船遗迹，南侧高温反应指向火山，西侧医疗应答指向废弃医疗舱。", "importance": "major", "visibility": "player_visible", "result_key": "radar_clues_found" }, "failure_policy": "fail_event", "record_policy": { "write_event_log": false, "write_world_history": false } }
          ]
        },
        {
          "id": "repair_docs_rewards",
          "effects": [
            { "id": "repair_docs_available_flag", "type": "set_world_flag", "target": { "type": "world_flags" }, "params": { "key": "repair_docs_available", "value": true, "tags": ["mainline", "repair"] }, "failure_policy": "fail_event", "record_policy": { "write_event_log": false, "write_world_history": false } },
            { "id": "learn_repair_tech", "type": "add_crew_condition", "target": { "type": "primary_crew" }, "params": { "condition": "knows_repair_tech" }, "failure_policy": "fail_event", "record_policy": { "write_event_log": false, "write_world_history": false } },
            { "id": "reveal_repair_docs", "type": "update_tile_state", "target": { "type": "event_tile" }, "params": { "object_id": "mainline-repair-docs", "revealed": true }, "failure_policy": "skip_effect", "record_policy": { "write_event_log": false, "write_world_history": false } },
            { "id": "repair_docs_log_effect", "type": "add_event_log", "target": { "type": "event_log" }, "params": { "summary": "坠毁日志中的技术文档已保存，当前队员掌握维修技术；其他队员之后可在日志技术文档处重复学习。", "importance": "major", "visibility": "player_visible", "result_key": "repair_docs_available" }, "failure_policy": "fail_event", "record_policy": { "write_event_log": false, "write_world_history": false } }
          ]
        }
      ],
      "log_templates": [
        { "id": "crash_site_survey_counter_log", "summary": "坠毁点调查计数已更新", "importance": "minor", "visibility": "player_visible" },
        { "id": "main_objective_started_log", "summary": "返航主目标已建立", "importance": "major", "visibility": "player_visible" },
        { "id": "radar_clues_found_log", "summary": "坠毁点雷达线索已记录", "importance": "major", "visibility": "player_visible" },
        { "id": "repair_docs_available_log", "summary": "维修技术文档已保存", "importance": "major", "visibility": "player_visible" }
      ],
      "content_refs": { "call_template_ids": ["mainline_crash_site_survey_chain.call.first", "mainline_crash_site_survey_chain.call.radar", "mainline_crash_site_survey_chain.call.repair_docs"], "item_ids": ["ration", "basic_tool", "signal_flare"] },
      "sample_contexts": [
        { "trigger_type": "action_complete", "occurred_at": 120, "source": "crew_action", "crew_id": "mike", "tile_id": "4-4", "action_id": "survey:mainline-damaged-warp-pod:4-4:60", "event_id": null, "event_definition_id": null, "node_id": null, "call_id": null, "objective_id": null, "selected_option_id": null, "world_flag_key": null, "proximity": null, "payload": { "action_type": "survey", "object_id": "mainline-damaged-warp-pod", "tags": ["mainline", "mainline_crash_site", "warp_pod"] } }
      ]
    },
    {
      "schema_version": "event-program-model-v1",
      "id": "mainline_repair_docs_repeat_learning",
      "version": 1,
      "domain": "mainline_crash_site",
      "title": "重复学习维修技术",
      "summary": "缺少维修技术的队员可在坠毁点日志技术文档处重复学习。",
      "tags": ["mainline", "crash_site", "repair_docs", "repeatable_knowledge"],
      "status": "approved",
      "trigger": {
        "type": "action_complete",
        "required_context": ["crew_id", "tile_id", "action_id"],
        "conditions": [
          { "type": "world_flag_equals", "field": "repair_docs_available", "value": true },
          { "type": "not", "conditions": [{ "type": "has_condition", "target": { "type": "primary_crew" }, "value": "knows_repair_tech" }] },
          { "type": "handler_condition", "handler_type": "trigger_context_value_equals", "params": { "field": "payload.object_id", "value": "mainline-repair-docs" } },
          { "type": "handler_condition", "handler_type": "trigger_context_value_equals", "params": { "field": "payload.action_type", "value": "survey" } }
        ]
      },
      "candidate_selection": { "priority": 85, "weight": 1, "mutex_group": null, "max_instances_per_trigger": 1, "requires_blocking_slot": false },
      "repeat_policy": { "scope": "crew", "max_trigger_count": null, "cooldown_seconds": 0, "history_key_template": "mainline_repair_docs_repeat_learning:{crew_id}", "allow_while_active": false },
      "event_graph": {
        "entry_node_id": "learn_report",
        "nodes": [
          { "id": "learn_report", "type": "call", "title": "报告维修技术学习", "call_template_id": "mainline_repair_docs_repeat_learning.call.learn", "speaker_crew_ref": { "type": "primary_crew" }, "urgency": "normal", "delivery": "queued_message", "options": [{ "id": "learn", "effect_refs": ["repeat_learn_repair_tech"], "is_default": true }], "option_node_mapping": { "learn": "learn_end" }, "blocking": { "occupies_crew_action": false, "occupies_communication": true, "blocking_key_template": null }, "expires_in_seconds": 240 },
          { "id": "learn_end", "type": "end", "title": "维修技术已补学", "resolution": "resolved", "result_key": "repair_tech_learned", "event_log_template_id": "repair_tech_learned_log", "history_writes": [{ "key_template": "mainline_repair_docs_repeat_learning:{crew_id}", "scope": "crew", "value": "repair_tech_learned" }], "blocking": { "occupies_crew_action": false, "occupies_communication": false, "blocking_key_template": null }, "cleanup_policy": { "release_blocking_claims": true, "delete_active_calls": true, "keep_player_summary": true } }
        ],
        "edges": [],
        "terminal_node_ids": ["learn_end"],
        "graph_rules": { "acyclic": true, "max_active_nodes": 1, "allow_parallel_nodes": false }
      },
      "effect_groups": [{ "id": "repeat_learn_repair_tech", "effects": [
        { "id": "repeat_learn_repair_condition", "type": "add_crew_condition", "target": { "type": "primary_crew" }, "params": { "condition": "knows_repair_tech" }, "failure_policy": "fail_event", "record_policy": { "write_event_log": false, "write_world_history": false } },
        { "id": "repeat_learn_repair_log_effect", "type": "add_event_log", "target": { "type": "event_log" }, "params": { "summary": "队员通过坠毁点日志技术文档补学了维修技术。", "importance": "normal", "visibility": "player_visible", "result_key": "repair_tech_learned" }, "failure_policy": "fail_event", "record_policy": { "write_event_log": false, "write_world_history": false } }
      ] }],
      "log_templates": [{ "id": "repair_tech_learned_log", "summary": "维修技术已补学", "importance": "normal", "visibility": "player_visible" }],
      "content_refs": { "call_template_ids": ["mainline_repair_docs_repeat_learning.call.learn"] },
      "sample_contexts": [
        { "trigger_type": "action_complete", "occurred_at": 360, "source": "crew_action", "crew_id": "amy", "tile_id": "4-4", "action_id": "survey:mainline-repair-docs:4-4:60", "event_id": null, "event_definition_id": null, "node_id": null, "call_id": null, "objective_id": null, "selected_option_id": null, "world_flag_key": null, "proximity": null, "payload": { "action_type": "survey", "object_id": "mainline-repair-docs", "tags": ["repair_docs", "mainline_crash_site"] } }
      ]
    }
  ]
}
