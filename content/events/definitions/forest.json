    {
      "schema_version": "event-program-model-v1",
      "id": "forest_beast_encounter",
      "version": 1,
      "domain": "forest",
      "title": "Forest Beast Encounter",
      "summary": "A forest idle event escalates through two urgent calls around a nearby beast.",
      "tags": ["sample", "emergency_multi_call", "forest"],
      "status": "approved",
      "trigger": {
        "type": "idle_time",
        "required_context": ["crew_id", "tile_id"],
        "conditions": [
          {
            "type": "has_tag",
            "target": {
              "type": "event_tile"
            },
            "field": "danger_tags",
            "value": "beast_tracks"
          }
        ]
      },
      "candidate_selection": {
        "priority": 90,
        "weight": 1,
        "mutex_group": "crew_emergency",
        "max_instances_per_trigger": 1,
        "requires_blocking_slot": true
      },
      "repeat_policy": {
        "scope": "crew_tile",
        "max_trigger_count": 1,
        "cooldown_seconds": 300,
        "history_key_template": "event:{event_definition_id}:{crew_id}:{tile_id}",
        "allow_while_active": false
      },
      "event_graph": {
        "entry_node_id": "beast_first_call",
        "nodes": [
          {
            "id": "beast_first_call",
            "type": "call",
            "title": "First beast contact",
            "call_template_id": "forest_beast_encounter.call.first",
            "speaker_crew_ref": {
              "type": "primary_crew"
            },
            "urgency": "emergency",
            "delivery": "incoming_call",
            "options": [
              {
                "id": "hold_position",
                "effect_refs": ["beast_hold_effect"],
                "is_default": true
              },
              {
                "id": "fall_back"
              }
            ],
            "option_node_mapping": {
              "hold_position": "beast_wait",
              "fall_back": "beast_retreat_end"
            },
            "blocking": {
              "occupies_crew_action": false,
              "occupies_communication": true,
              "blocking_key_template": null
            },
            "expires_in_seconds": 90
          },
          {
            "id": "beast_wait",
            "type": "wait",
            "title": "Wait for the beast to pass",
            "duration_seconds": 20,
            "wake_trigger_type": "time_wakeup",
            "next_node_id": "beast_followup_call",
            "set_next_wakeup_at": true,
            "crew_action_during_wait": {
              "type": "guarding_event_site",
              "status": "active",
              "action_params": {
                "stance": "silent"
              }
            },
            "interrupt_policy": "not_interruptible",
            "on_interrupted": null,
            "blocking": {
              "occupies_crew_action": true,
              "occupies_communication": false,
              "blocking_key_template": null
            }
          },
          {
            "id": "beast_followup_call",
            "type": "call",
            "title": "Follow-up beast call",
            "call_template_id": "forest_beast_encounter.call.followup",
            "speaker_crew_ref": {
              "type": "primary_crew"
            },
            "urgency": "urgent",
            "delivery": "incoming_call",
            "options": [
              {
                "id": "drive_off",
                "is_default": true
              },
              {
                "id": "stay_hidden"
              }
            ],
            "option_node_mapping": {
              "drive_off": "beast_safe_end",
              "stay_hidden": "beast_shaken_end"
            },
            "blocking": {
              "occupies_crew_action": false,
              "occupies_communication": true,
              "blocking_key_template": null
            },
            "expires_in_seconds": 120
          },
          {
            "id": "beast_safe_end",
            "type": "end",
            "title": "Beast driven away",
            "resolution": "resolved",
            "result_key": "beast_driven_off",
            "final_effect_refs": ["beast_safe_effects"],
            "event_log_template_id": "beast_safe_log",
            "history_writes": [
              {
                "key_template": "forest_beast_encounter:{crew_id}:{tile_id}",
                "scope": "crew_tile",
                "value": "beast_driven_off"
              }
            ],
            "blocking": {
              "occupies_crew_action": false,
              "occupies_communication": false,
              "blocking_key_template": null
            },
            "cleanup_policy": {
              "release_blocking_claims": true,
              "delete_active_calls": true,
              "keep_player_summary": true
            }
          },
          {
            "id": "beast_shaken_end",
            "type": "end",
            "title": "Crew stays hidden",
            "resolution": "resolved",
            "result_key": "beast_avoided",
            "final_effect_refs": ["beast_hidden_effects"],
            "event_log_template_id": "beast_hidden_log",
            "history_writes": [
              {
                "key_template": "forest_beast_encounter:{crew_id}:{tile_id}",
                "scope": "crew_tile",
                "value": "beast_avoided"
              }
            ],
            "blocking": {
              "occupies_crew_action": false,
              "occupies_communication": false,
              "blocking_key_template": null
            },
            "cleanup_policy": {
              "release_blocking_claims": true,
              "delete_active_calls": true,
              "keep_player_summary": true
            }
          },
          {
            "id": "beast_retreat_end",
            "type": "end",
            "title": "Crew retreats",
            "resolution": "resolved",
            "result_key": "beast_retreat",
            "final_effect_refs": ["beast_retreat_effects"],
            "event_log_template_id": "beast_retreat_log",
            "history_writes": [
              {
                "key_template": "forest_beast_encounter:{crew_id}:{tile_id}",
                "scope": "crew_tile",
                "value": "beast_retreat"
              }
            ],
            "blocking": {
              "occupies_crew_action": false,
              "occupies_communication": false,
              "blocking_key_template": null
            },
            "cleanup_policy": {
              "release_blocking_claims": true,
              "delete_active_calls": true,
              "keep_player_summary": true
            }
          }
        ],
        "edges": [],
        "terminal_node_ids": ["beast_safe_end", "beast_shaken_end", "beast_retreat_end"],
        "graph_rules": {
          "acyclic": true,
          "max_active_nodes": 1,
          "allow_parallel_nodes": false
        }
      },
      "effect_groups": [
        {
          "id": "beast_hold_effect",
          "effects": [
