          "action_id": "amy-survey-2-3",
          "event_id": null,
          "event_definition_id": null,
          "node_id": null,
          "call_id": null,
          "objective_id": null,
          "selected_option_id": null,
          "world_flag_key": null,
          "proximity": null,
          "payload": {
            "action_type": "survey"
          }
        }
      ]
    },
    {
      "schema_version": "event-program-model-v1",
      "id": "forest_beast_emergency",
