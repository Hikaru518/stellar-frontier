{
  "event_definitions": [
    {
      "schema_version": "event-program-model-v1",
      "id": "mainline_rare_ore_gather_progress",
      "version": 1,
      "domain": "mainline_resources",
      "title": "丘陵稀有矿石采集进度",
      "summary": "丘陵铁矿床采集继续保留基础铁矿收益，同时递增稀有矿石采集计数；第 3 次起保底给当前队员稀有矿石样本。",
