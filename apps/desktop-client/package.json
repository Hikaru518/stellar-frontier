{
  "name": "@stellar-frontier/desktop-client",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop shell for the Stellar Frontier PC client.",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "test": "tsc --noEmit -p tsconfig.json",
    "package:win": "node scripts/package-win.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3"
  },
  "build": {
    "appId": "com.stellarfrontier.console",
    "productName": "Stellar Frontier",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      {
        "from": "../pc-client/dist",
        "to": "pc-client-dist",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    }
  }
}
